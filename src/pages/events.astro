---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
  title={`AI Events in Asia — ${siteConfig.name}`}
  description="Discover AI conferences, meetups, and workshops happening across Asia."
  canonical={`${siteConfig.url}/events`}
>
  <SiteHeader currentPath="/events" />
  <main id="main-content">
    <div class="border-b border-border/40" style="border-top:4px solid hsl(var(--primary))">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold">AI Events in Asia</h1>
        <p class="text-muted-foreground mt-1 max-w-xl">Conferences, meetups, workshops, and summits for Asia's AI community.</p>
      </div>
    </div>

    <section class="container mx-auto px-4 py-16">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5" style="background-color:hsl(var(--primary)/0.1)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        </div>
        <h2 class="text-xl font-bold mb-3">Events directory coming soon</h2>
        <p class="text-muted-foreground text-sm leading-relaxed mb-6">
          We're building a comprehensive directory of AI events across Asia.
          In the meantime, follow our newsletter for event announcements.
        </p>
        <a
          href="/newsletter"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-white transition-opacity hover:opacity-90"
          style="background-color:hsl(var(--primary))"
        >
          Subscribe to Newsletter
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
