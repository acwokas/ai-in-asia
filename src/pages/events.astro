---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { format } from 'date-fns';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const { data: events } = await supabase
  .from('events')
  .select('id, title, slug, start_date, end_date, city, country, region, event_type, website_url, registration_url, is_featured, description')
  .eq('status', 'upcoming')
  .order('start_date', { ascending: true })
  .limit(50);

const allEvents = (events || []) as any[];

const eventTypeLabel: Record<string, string> = {
  conference: 'Conference',
  meetup: 'Meetup',
  workshop: 'Workshop',
  summit: 'Summit',
  webinar: 'Webinar',
  hackathon: 'Hackathon',
};
---

<BaseLayout
  title={`AI Events in Asia — ${siteConfig.name}`}
  description="Discover AI conferences, meetups, and workshops happening across Asia."
  canonical={`${siteConfig.url}/events`}
>
  <SiteHeader currentPath="/events" />
  <main id="main-content">
    <div class="border-b border-border/40" style="border-top:4px solid hsl(var(--primary))">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold">AI Events in Asia</h1>
        <p class="text-muted-foreground mt-1 max-w-xl">Conferences, meetups, workshops, and summits for Asia's AI community.</p>
      </div>
    </div>

    <section class="container mx-auto px-4 py-8">
      {allEvents.length === 0 ? (
        <div class="max-w-lg mx-auto text-center py-16">
          <p class="text-muted-foreground">No upcoming events — check back soon or subscribe to our newsletter for announcements.</p>
          <a href="/newsletter" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 rounded-lg font-semibold text-white hover:opacity-90 transition-opacity" style="background-color:hsl(var(--primary))">
            Subscribe to Newsletter
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {allEvents.map((event: any) => (
            <a
              href={event.website_url || event.registration_url || '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-xl border border-border bg-card p-5 hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
              style="border-left:4px solid hsl(var(--primary));box-shadow:var(--shadow-card)"
            >
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white" style="background-color:hsl(var(--primary))">
                  {eventTypeLabel[event.event_type] || event.event_type || 'Event'}
                </span>
                {event.is_featured && (
                  <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide bg-amber-500/20 text-amber-500">
                    Featured
                  </span>
                )}
              </div>
              <h2 class="font-bold text-sm leading-snug group-hover:text-primary transition-colors duration-200 mb-2 line-clamp-2">{event.title}</h2>
              {event.description && (
                <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{event.description}</p>
              )}
              <div class="flex flex-col gap-1 text-xs text-muted-foreground mt-auto pt-1">
                {event.start_date && (
                  <span class="flex items-center gap-1">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    {format(new Date(event.start_date), 'MMM d, yyyy')}
                    {event.end_date && ` – ${format(new Date(event.end_date), 'MMM d')}`}
                  </span>
                )}
                {(event.city || event.country) && (
                  <span class="flex items-center gap-1">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    {[event.city, event.country].filter(Boolean).join(', ')}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
