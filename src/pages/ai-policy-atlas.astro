---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

// Fetch articles from the Policy category
const { data: policyCategory } = await supabase
  .from('categories')
  .select('id')
  .eq('slug', 'policy')
  .maybeSingle();

const { data: articles } = await supabase
  .from('articles')
  .select(`
    id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
    authors:author_id (name),
    categories:primary_category_id (name, slug)
  `)
  .eq('status', 'published')
  .eq('primary_category_id', policyCategory?.id || '07c78bbe-d56f-4698-8bdd-8444364551da')
  .order('published_at', { ascending: false })
  .limit(48);

const policyArticles = (articles || []) as any[];
const catColor = 'hsl(var(--primary))';
---

<BaseLayout
  title={`AI Policy Atlas — ${siteConfig.name}`}
  description="Track AI policy, regulation, and governance developments across Asia-Pacific."
  canonical={`${siteConfig.url}/ai-policy-atlas`}
>
  <SiteHeader currentPath="/ai-policy-atlas" />
  <main id="main-content">
    <div class="border-b border-border/40" style={`border-top:4px solid ${catColor}`}>
      <div class="container mx-auto px-4 py-8">
        <div class="flex items-end gap-4">
          <div>
            <span
              class="inline-block px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wide text-white mb-3"
              style={`background-color:${catColor}`}
            >
              Policy Atlas
            </span>
            <h1 class="text-3xl font-bold">AI Policy Atlas</h1>
            <p class="text-muted-foreground mt-1 max-w-xl">Track AI regulation, governance, and policy developments across Asia-Pacific.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Region filter -->
    <section class="container mx-auto px-4 py-8 border-b border-border/30">
      <h2 class="font-display text-xl font-bold mb-5">Filter by Country / Region</h2>
      <div class="flex flex-wrap gap-2">
        {(['All', 'China', 'Japan', 'South Korea', 'Singapore', 'India', 'ASEAN', 'Australia', 'Taiwan', 'Hong Kong'] as string[]).map((region) => (
          <button
            class="region-filter px-3 py-1.5 rounded-lg border text-sm font-medium transition-all"
            data-region={region}
            style={region === 'All' ? `background-color:${catColor};border-color:${catColor};color:white` : 'border-color:hsl(var(--border));color:hsl(var(--muted-foreground))'}
          >
            {region}
          </button>
        ))}
      </div>
    </section>

    <!-- Policy articles -->
    <section class="container mx-auto px-4 py-8">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-display text-xl font-bold">Latest Policy News</h2>
        <span id="article-count" class="text-sm text-muted-foreground">{policyArticles.length} articles</span>
      </div>
      {policyArticles.length === 0 ? (
        <p class="text-center text-muted-foreground py-12">No policy articles yet — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
          {policyArticles.map((article: any) => {
            const color = getCategoryColor(article.categories?.slug || '');
            const titleLower = article.title.toLowerCase() + ' ' + (article.excerpt || '').toLowerCase();
            const regionTags = [
              titleLower.includes('china') || titleLower.includes('beijing') || titleLower.includes('chinese') ? 'China' : '',
              titleLower.includes('japan') || titleLower.includes('tokyo') || titleLower.includes('japanese') ? 'Japan' : '',
              titleLower.includes('south korea') || titleLower.includes('korea') || titleLower.includes('seoul') ? 'South Korea' : '',
              titleLower.includes('singapore') ? 'Singapore' : '',
              titleLower.includes('india') || titleLower.includes('delhi') || titleLower.includes('mumbai') ? 'India' : '',
              titleLower.includes('asean') || titleLower.includes('southeast asia') ? 'ASEAN' : '',
              titleLower.includes('australia') || titleLower.includes('sydney') || titleLower.includes('canberra') ? 'Australia' : '',
              titleLower.includes('taiwan') ? 'Taiwan' : '',
              titleLower.includes('hong kong') ? 'Hong Kong' : '',
            ].filter(Boolean).join(',');
            return (
              <a
                href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                class="policy-article group block rounded-lg overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                style={`border-left:4px solid ${color};box-shadow:var(--shadow-card)`}
                data-regions={regionTags || 'All'}
              >
                {article.featured_image_url ? (
                  <img
                    src={getOptimizedThumbnail(article.featured_image_url)}
                    alt={article.title}
                    class="w-full h-44 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-44" style={`background:${color}15`} />
                )}
                <div class="p-4">
                  <h3 class="font-semibold text-sm leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200 mb-2">{article.title}</h3>
                  {article.excerpt && (
                    <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{article.excerpt}</p>
                  )}
                  <div class="flex items-center gap-2 text-xs text-muted-foreground">
                    {article.authors && <span>{article.authors.name}</span>}
                    {article.published_at && (
                      <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                    )}
                    {article.reading_time_minutes && <span>· {article.reading_time_minutes} min</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.region-filter');
  const articles = document.querySelectorAll<HTMLElement>('.policy-article');
  const countEl = document.getElementById('article-count');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const region = btn.dataset.region || 'All';
      filterBtns.forEach(b => {
        const active = b.dataset.region === region;
        b.style.cssText = active
          ? 'background-color:hsl(var(--primary));border-color:hsl(var(--primary));color:white'
          : 'border-color:hsl(var(--border));color:hsl(var(--muted-foreground));background:';
      });
      let visible = 0;
      articles.forEach(card => {
        const regions = card.dataset.regions || '';
        const show = region === 'All' || regions.includes(region);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `${visible} articles`;
    });
  });
</script>
