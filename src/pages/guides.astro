---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

// Fetch articles from the 'learn' category as guides
const { data: guides } = await supabase
  .from('articles')
  .select(`
    id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
    authors:author_id (name),
    categories:primary_category_id (name, slug)
  `)
  .eq('status', 'published')
  .order('published_at', { ascending: false })
  .limit(24);

const articles = (guides || []) as any[];
---

<BaseLayout
  title={`Guides — ${siteConfig.name}`}
  description="Step-by-step AI guides for every skill level, curated for Asia."
  canonical={`${siteConfig.url}/guides`}
>
  <SiteHeader currentPath="/guides" />
  <main id="main-content">
    <div class="border-b border-border/40" style="border-top:4px solid hsl(var(--primary))">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold">Guides</h1>
        <p class="text-muted-foreground mt-1 max-w-xl">Step-by-step AI guides for professionals and enthusiasts across Asia.</p>
      </div>
    </div>

    <section class="container mx-auto px-4 py-8">
      {articles.length === 0 ? (
        <div class="py-16 text-center text-muted-foreground">
          <p class="text-lg font-semibold mb-2">Guides coming soon</p>
          <p class="text-sm">We're building out our guides section. Check back soon.</p>
          <a href="/" class="mt-6 inline-block text-primary hover:underline text-sm">← Back to home</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {articles.map((article: any) => {
            const catColor = getCategoryColor(article.categories?.slug || '');
            return (
              <a
                href={`/${article.categories?.slug || 'learn'}/${article.slug}`}
                class="group block rounded-lg overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                style={`border-left:4px solid ${catColor};box-shadow:var(--shadow-card)`}
              >
                {article.featured_image_url ? (
                  <img
                    src={getOptimizedThumbnail(article.featured_image_url)}
                    alt={article.title}
                    class="w-full h-44 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-44" style={`background:${catColor}15`} />
                )}
                <div class="p-4">
                  {article.categories && (
                    <span
                      class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white mb-2"
                      style={`background-color:${catColor}`}
                    >
                      {article.categories.name}
                    </span>
                  )}
                  <h3 class="font-semibold text-sm leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200 mb-2">{article.title}</h3>
                  {article.excerpt && (
                    <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{article.excerpt}</p>
                  )}
                  <div class="flex items-center gap-2 text-xs text-muted-foreground">
                    {article.authors && <span>{article.authors.name}</span>}
                    {article.published_at && (
                      <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                    )}
                    {article.reading_time_minutes && <span>· {article.reading_time_minutes} min read</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
