---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedHeroImage, getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HomeSectionsIsland from '../components/islands/HomeSectionsIsland';
import NewsletterIsland from '../components/islands/NewsletterIsland';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const oneMonthAgo = new Date();
oneMonthAgo.setMonth(oneMonthAgo.getMonth() - 1);

const oneWeekAgo = new Date();
oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);

const [
  { data: featuredArticles },
  { data: trendingArticles },
  totalRes,
  weekRes,
] = await Promise.all([
  supabase
    .from('articles')
    .select(`
      id, title, slug, excerpt, featured_image_url, reading_time_minutes,
      published_at, updated_at, cornerstone, sticky, is_trending,
      authors:author_id (name, slug),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .eq('featured_on_homepage', true)
    .gte('published_at', oneMonthAgo.toISOString())
    .order('sticky', { ascending: false })
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(18),

  supabase
    .from('articles')
    .select(`
      id, title, slug, featured_image_url, reading_time_minutes, published_at, is_trending,
      authors:author_id (name),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .eq('homepage_trending', true)
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(6),

  supabase.from('articles').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  supabase.from('articles').select('id', { count: 'exact', head: true }).eq('status', 'published').gte('published_at', oneWeekAgo.toISOString()),
]);

const totalArticles = totalRes.count ?? 0;
const thisWeekCount = weekRes.count ?? 0;

const featured = featuredArticles?.[0];
const latestArticles = featuredArticles?.slice(1, 16) || [];
const secondaryHero = latestArticles.slice(0, 4);
const gridArticles = latestArticles.slice(4);

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  name: siteConfig.name,
  url: siteConfig.url,
  logo: `${siteConfig.url}/favicon.png`,
  description: siteConfig.description,
  foundingDate: '2024',
  areaServed: { '@type': 'Place', name: 'Asia' },
  publishingPrinciples: `${siteConfig.url}/about`,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: siteConfig.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.url}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout jsonLd={[orgJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main id="main-content">

    {featured ? (
      <section class="container mx-auto px-4 pt-4 pb-3">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">

          <!-- Primary hero -->
          <a
            href={`/${(featured as any).categories?.slug || 'news'}/${featured.slug}`}
            class="article-hero lg:col-span-8 group"
            style={{ minHeight: '440px' }}
          >
            {featured.featured_image_url ? (
              <img
                src={getOptimizedHeroImage(featured.featured_image_url)}
                alt={featured.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="eager"
                fetchpriority="high"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-background" />
            )}
            <div class="article-hero-gradient" />
            <div class="article-hero-content">
              {(featured as any).categories && (
                <span
                  class="inline-block px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wide text-white mb-3"
                  style={`background-color:${getCategoryColor((featured as any).categories.slug)}`}
                >
                  {(featured as any).categories.name}
                </span>
              )}
              {(featured as any).is_trending && (
                <span class="inline-block ml-2 px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wide text-white mb-3" style="background-color:#E06050">Trending</span>
              )}
              <h1 class="article-hero-title transition-colors group-hover:text-amber-300">{featured.title}</h1>
              {featured.excerpt && (
                <p class="article-hero-excerpt hidden sm:block line-clamp-2">{featured.excerpt}</p>
              )}
              <div class="flex flex-wrap items-center gap-3 text-white/60 text-xs mt-2">
                {(featured as any).authors && <span>{(featured as any).authors.name}</span>}
                {featured.published_at && (
                  <time datetime={featured.published_at}>
                    {format(new Date(featured.published_at), 'MMM d, yyyy')}
                  </time>
                )}
                {featured.reading_time_minutes && <span>{featured.reading_time_minutes} min read</span>}
              </div>
            </div>
          </a>

          <!-- Secondary 2x2 cards -->
          <div class="lg:col-span-4 grid grid-cols-2 gap-3 lg:h-[440px]">
            {secondaryHero.map((article: any) => (
              <a
                href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                class="group rounded-lg overflow-hidden border border-border/50 flex flex-col hover:border-border transition-colors"
                style={`border-top:3px solid ${getCategoryColor(article.categories?.slug || '')}`}
              >
                {article.featured_image_url ? (
                  <img
                    src={getOptimizedThumbnail(article.featured_image_url)}
                    alt={article.title}
                    class="w-full h-[110px] lg:h-[130px] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="w-full h-[110px] lg:h-[130px]"
                    style={`background:${getCategoryColor(article.categories?.slug || '')}20`}
                  />
                )}
                <div class="p-2.5 flex flex-col flex-1 gap-1">
                  {article.categories && (
                    <span
                      class="inline-block px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide text-white w-fit"
                      style={`background-color:${getCategoryColor(article.categories.slug)}`}
                    >
                      {article.categories.name}
                    </span>
                  )}
                  <h3 class="text-xs font-semibold leading-tight line-clamp-3 transition-colors group-hover:text-primary">{article.title}</h3>
                  <div class="flex items-center gap-1.5 mt-auto pt-1 text-[10px] text-muted-foreground flex-wrap">
                    {article.published_at && (
                      <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                    )}
                    {article.reading_time_minutes && <span>· {article.reading_time_minutes} min read</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="lg:col-span-12 flex justify-end">
            <a href="/articles" class="text-sm font-medium text-primary hover:text-primary/80 transition-colors">View all latest articles</a>
          </div>
        </div>
      </section>
    ) : (
      <section class="container mx-auto px-4 py-8 text-center text-muted-foreground">
        <p>No featured articles today — check back soon.</p>
      </section>
    )}

    <!-- Stats bar -->
    {totalArticles > 0 && (
      <div class="container mx-auto px-4 py-3 border-t border-border/30">
        <div class="flex items-center gap-6 md:gap-10">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
            <span class="font-display text-lg font-bold text-foreground">{totalArticles.toLocaleString()}</span>
            <span class="text-xs text-muted-foreground">Total Articles</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
            <span class="font-display text-lg font-bold text-foreground">+{thisWeekCount}</span>
            <span class="text-xs text-muted-foreground">This Week</span>
          </div>
        </div>
      </div>
    )}

    <!-- Latest Stories grid -->
    {gridArticles.length > 0 && (
      <section class="container mx-auto px-4 py-6 border-t border-border/30">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs font-bold text-muted-foreground uppercase tracking-widest">Latest Stories</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-start">
          {gridArticles.map((article: any, i: number) => {
            const isFeatured = i === 0 || i === 4;
            const catColor = getCategoryColor(article.categories?.slug || '');
            const catSlug = article.categories?.slug || 'news';
            return (
              <a
                href={`/${catSlug}/${article.slug}`}
                class={`group block rounded-lg overflow-hidden border border-border hover:-translate-y-1 hover:shadow-lg transition-all duration-300 ${isFeatured ? 'md:col-span-2' : ''}`}
                style={`border-left:4px solid ${catColor}`}
              >
                {article.featured_image_url ? (
                  <img
                    src={getOptimizedThumbnail(article.featured_image_url)}
                    alt={article.title}
                    class={`w-full object-cover transition-transform duration-500 group-hover:scale-[1.02] ${isFeatured ? 'h-56' : 'h-40'}`}
                    loading="lazy"
                  />
                ) : (
                  <div
                    class={`w-full ${isFeatured ? 'h-56' : 'h-40'}`}
                    style={`background:${catColor}15`}
                  />
                )}
                <div class="p-4">
                  {article.categories && (
                    <span
                      class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white mb-2"
                      style={`background-color:${catColor}`}
                    >
                      {article.categories.name}
                    </span>
                  )}
                  <h3 class={`font-bold leading-snug transition-colors group-hover:text-primary ${isFeatured ? 'text-xl line-clamp-2' : 'text-sm line-clamp-3'}`}>
                    {article.title}
                  </h3>
                  {isFeatured && article.excerpt && (
                    <p class="text-sm text-muted-foreground mt-1.5 line-clamp-2">{article.excerpt}</p>
                  )}
                  <div class="flex items-center gap-2 mt-3 text-xs text-muted-foreground">
                    {article.published_at && (
                      <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                    )}
                    {article.reading_time_minutes && <span>· {article.reading_time_minutes} min read</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Trending -->
    {trendingArticles && trendingArticles.length > 0 && (
      <section class="container mx-auto px-4 py-8 border-t border-border/30">
        <h2 class="text-xs font-bold mb-4 text-muted-foreground uppercase tracking-widest">Trending Now</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-4">
          {trendingArticles.map((article: any, i: number) => (
            <a
              href={`/${article.categories?.slug || 'news'}/${article.slug}`}
              class="group flex gap-3 items-start py-2 border-b border-border/20"
            >
              <span class="text-4xl font-black text-muted-foreground/20 leading-none w-10 shrink-0 select-none tabular-nums">
                {i + 1}
              </span>
              <div>
                {article.categories && (
                  <span
                    class="inline-block px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide text-white mb-1"
                    style={`background-color:${getCategoryColor(article.categories?.slug || '')}`}
                  >
                    {article.categories.name}
                  </span>
                )}
                <h3 class="text-sm font-semibold leading-snug transition-colors group-hover:text-primary line-clamp-3">{article.title}</h3>
                <div class="flex items-center gap-2 mt-1 text-xs text-muted-foreground">
                  {article.published_at && (
                    <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                  )}
                  {article.reading_time_minutes && <span>· {article.reading_time_minutes} min read</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Newsletter CTA -->
    <section class="container mx-auto px-4 py-10 border-t border-border/30">
      <NewsletterIsland
        client:only="react"
        supabaseUrl={siteConfig.supabaseUrl}
        supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
      />
    </section>

    <!-- Below-fold: more stories -->
    <HomeSectionsIsland
      client:only="react"
      supabaseUrl={siteConfig.supabaseUrl}
      supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
    />

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-hero {
    position: relative;
    display: block;
    border-radius: 0.5rem;
    overflow: hidden;
    background: hsl(var(--muted));
  }
  .article-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(4,4,5,0.95) 0%, rgba(4,4,5,0.7) 40%, rgba(4,4,5,0.2) 70%, transparent 100%);
    pointer-events: none;
  }
  .article-hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
  }
  .article-hero-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    color: white;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }
  .article-hero-excerpt {
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }
</style>
