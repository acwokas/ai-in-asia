---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedHeroImage, getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ThreeBeforeNineTickerStrip from '../components/ThreeBeforeNineTickerStrip.astro';
import HomeSectionsIsland from '../components/islands/HomeSectionsIsland';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const oneMonthAgo = new Date();
oneMonthAgo.setMonth(oneMonthAgo.getMonth() - 1);

const oneWeekAgo = new Date();
oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);

const [
  { data: featuredArticles },
  { data: trendingArticles },
  { data: editorsPick },
  { data: latestStories },
  totalRes,
  weekRes,
] = await Promise.all([
  supabase
    .from('articles')
    .select(`
      id, title, slug, excerpt, featured_image_url, reading_time_minutes,
      published_at, updated_at, cornerstone, sticky, is_trending,
      authors:author_id (name, slug),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .eq('featured_on_homepage', true)
    .gte('published_at', oneMonthAgo.toISOString())
    .order('sticky', { ascending: false })
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(18),

  supabase
    .from('articles')
    .select(`
      id, title, slug, featured_image_url, reading_time_minutes, published_at, is_trending,
      authors:author_id (name),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .eq('homepage_trending', true)
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(6),

  // Editor's pick for homepage
  supabase
    .from('editors_picks')
    .select(`
      article_id,
      articles (
        id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
        authors:author_id (name),
        categories:primary_category_id (name, slug)
      )
    `)
    .eq('location', 'homepage')
    .limit(1)
    .maybeSingle(),

  // Latest stories - recent articles regardless of featured flag
  supabase
    .from('articles')
    .select(`
      id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
      authors:author_id (name),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(9),

  supabase.from('articles').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  supabase.from('articles').select('id', { count: 'exact', head: true }).eq('status', 'published').gte('published_at', oneWeekAgo.toISOString()),
]);

const totalArticles = totalRes.count ?? 0;
const thisWeekCount = weekRes.count ?? 0;

const featured = featuredArticles?.[0];
const latestArticles = featuredArticles?.slice(1, 16) || [];
const secondaryHero = latestArticles.slice(0, 4);
const gridArticles = latestArticles.slice(4);

const editorArticle = (editorsPick as any)?.articles || null;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  name: siteConfig.name,
  url: siteConfig.url,
  logo: `${siteConfig.url}/favicon.png`,
  description: siteConfig.description,
  foundingDate: '2024',
  areaServed: { '@type': 'Place', name: 'Asia' },
  publishingPrinciples: `${siteConfig.url}/about`,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: siteConfig.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.url}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout jsonLd={[orgJsonLd, websiteJsonLd]}>
  <SiteHeader />
  <ThreeBeforeNineTickerStrip />

  <main id="main-content">

    {featured ? (
      <section class="container mx-auto px-4 pt-4 pb-3">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">

          <!-- Primary hero -->
          <a
            href={`/${(featured as any).categories?.slug || 'news'}/${featured.slug}`}
            class="article-hero lg:col-span-8 group"
          >
            {featured.featured_image_url ? (
              <img
                src={getOptimizedHeroImage(featured.featured_image_url)}
                alt={featured.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                loading="eager"
                fetchpriority="high"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-background" />
            )}
            <div class="article-hero-gradient" />
            <div class="article-hero-content">
              {(featured as any).categories && (
                <span
                  class="inline-block px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wider text-white mb-3"
                  style={`background-color:${getCategoryColor((featured as any).categories.slug)}`}
                >
                  {(featured as any).categories.name}
                </span>
              )}
              {(featured as any).is_trending && (
                <span class="inline-block ml-2 px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wider text-white mb-3" style="background-color:#E06050">Trending</span>
              )}
              <h1 class="article-hero-title transition-colors group-hover:text-amber-300">{featured.title}</h1>
              {featured.excerpt && (
                <p class="article-hero-excerpt hidden sm:block line-clamp-2">{featured.excerpt}</p>
              )}
              <div class="flex flex-wrap items-center gap-3 text-white/60 text-xs mt-2">
                {(featured as any).authors && <span>{(featured as any).authors.name}</span>}
                {featured.published_at && (
                  <time datetime={featured.published_at}>
                    {format(new Date(featured.published_at), 'MMM d, yyyy')}
                  </time>
                )}
                {featured.reading_time_minutes && <span>{featured.reading_time_minutes} min read</span>}
              </div>
            </div>
          </a>

          <!-- Secondary 2x2 cards -->
          <div class="lg:col-span-4 grid grid-cols-2 gap-3">
            {secondaryHero.map((article: any) => {
              const catColor = getCategoryColor(article.categories?.slug || '');
              return (
                <a
                  href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                  class="group rounded-lg overflow-hidden border border-border/50 bg-card flex flex-col hover:shadow-lg transition-all duration-300"
                  style={`border-left:4px solid ${catColor};box-shadow:var(--shadow-card)`}
                >
                  {article.featured_image_url ? (
                    <img
                      src={getOptimizedThumbnail(article.featured_image_url)}
                      alt={article.title}
                      class="w-full h-[120px] object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-[120px]" style={`background:${catColor}20`} />
                  )}
                  <div class="p-2.5 flex flex-col flex-1 gap-1">
                    {article.categories && (
                      <span
                        class="inline-block px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide text-white w-fit"
                        style={`background-color:${catColor}`}
                      >
                        {article.categories.name}
                      </span>
                    )}
                    <h3 class="text-[13px] font-semibold leading-[1.3] line-clamp-3 group-hover:text-primary transition-colors duration-200">{article.title}</h3>
                    <div class="flex items-center gap-1.5 mt-auto pt-1 text-[10px] text-muted-foreground">
                      {article.published_at && (
                        <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d')}</time>
                      )}
                      {article.reading_time_minutes && <span>· {article.reading_time_minutes} min</span>}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          <div class="lg:col-span-12 flex justify-end">
            <a href="/articles" class="text-sm font-medium text-primary hover:text-primary/80 transition-colors">View all latest articles</a>
          </div>
        </div>
      </section>
    ) : (
      <section class="container mx-auto px-4 py-8 text-center text-muted-foreground">
        <p>No featured articles today — check back soon.</p>
      </section>
    )}

    <!-- Stats bar - always visible -->
    {totalArticles > 0 && (
      <div class="container mx-auto px-4 py-3 border-t border-border/30">
        <div class="flex items-center gap-6 md:gap-10">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 shrink-0"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
            <span class="font-display text-lg font-bold text-foreground">{totalArticles.toLocaleString()}</span>
            <span class="text-xs text-muted-foreground">Total Articles</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 shrink-0"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
            <span class="font-display text-lg font-bold text-foreground">+{thisWeekCount}</span>
            <span class="text-xs text-muted-foreground">This Week</span>
          </div>
        </div>
      </div>
    )}

    <!-- Latest Stories -->
    {latestStories && latestStories.length > 0 && (
      <section class="container mx-auto px-4 py-8 border-t border-border/30">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <span class="px-2.5 py-1 rounded text-xs font-black uppercase tracking-widest text-white" style="background-color:hsl(var(--primary))">Latest</span>
            <h2 class="font-display text-2xl font-bold">Stories</h2>
          </div>
          <a href="/articles" class="text-sm text-muted-foreground hover:text-foreground transition-colors">View all →</a>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
          <!-- 3 large cards -->
          <div class="flex-1 min-w-0 grid grid-cols-1 md:grid-cols-3 gap-5">
            {latestStories.slice(0, 3).map((article: any) => {
              const catColor = getCategoryColor(article.categories?.slug || '');
              const catSlug = article.categories?.slug || 'news';
              return (
                <a
                  href={`/${catSlug}/${article.slug}`}
                  class="group flex flex-col rounded-xl overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-xl transition-all duration-300"
                  style={`border-left:4px solid ${catColor};box-shadow:var(--shadow-card)`}
                >
                  {article.featured_image_url ? (
                    <img
                      src={getOptimizedThumbnail(article.featured_image_url)}
                      alt={article.title}
                      class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-48" style={`background:${catColor}18`} />
                  )}
                  <div class="p-4 flex flex-col flex-1">
                    {article.categories && (
                      <span
                        class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white mb-2 w-fit"
                        style={`background-color:${catColor}`}
                      >
                        {article.categories.name}
                      </span>
                    )}
                    <h3 class="font-bold text-[16px] leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200 flex-1">
                      {article.title}
                    </h3>
                    <div class="flex items-center gap-2 mt-3 text-xs text-muted-foreground">
                      {article.published_at && (
                        <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                      )}
                      {article.reading_time_minutes && <span>· {article.reading_time_minutes} min read</span>}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          <!-- Right rail: ad unit -->
          <div class="lg:w-[300px] shrink-0">
            <div
              class="w-full max-w-[300px] h-[250px] rounded-lg border border-dashed border-border bg-muted/30 flex flex-col items-center justify-center gap-2 text-xs text-muted-foreground"
              data-ad-slot="homepage-latest-stories-300x250"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="opacity-40"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
              <span class="font-medium opacity-60">Advertisement</span>
              <span class="opacity-40">300×250</span>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Editor's Pick (SSR) -->
    {editorArticle && (
      <section class="border-t border-border/30 bg-muted/20">
        <div class="container mx-auto px-4 py-10">
          <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-4">Editor's Pick</p>
          <a
            href={`/${(editorArticle as any).categories?.slug || 'news'}/${(editorArticle as any).slug}`}
            class="group flex flex-col md:flex-row gap-6 rounded-xl overflow-hidden border border-border bg-card hover:border-primary/40 transition-all duration-300"
            style="box-shadow:var(--shadow-card)"
          >
            {(editorArticle as any).featured_image_url && (
              <img
                src={getOptimizedThumbnail((editorArticle as any).featured_image_url)}
                alt={(editorArticle as any).title}
                class="w-full md:w-80 h-52 md:h-auto object-cover shrink-0 transition-transform duration-500 group-hover:scale-[1.01]"
                loading="lazy"
              />
            )}
            <div class="p-4 md:p-6 flex flex-col justify-center">
              {(editorArticle as any).categories && (
                <span
                  class="text-xs font-bold uppercase tracking-wide mb-2"
                  style={`color:${getCategoryColor((editorArticle as any).categories.slug)}`}
                >
                  {(editorArticle as any).categories.name}
                </span>
              )}
              <h3 class="text-2xl font-bold leading-snug group-hover:text-primary transition-colors duration-200 mb-2">{(editorArticle as any).title}</h3>
              {(editorArticle as any).excerpt && (
                <p class="text-muted-foreground text-sm leading-relaxed line-clamp-3">{(editorArticle as any).excerpt}</p>
              )}
              <div class="flex items-center gap-3 mt-4 text-xs text-muted-foreground">
                {(editorArticle as any).authors && <span>{(editorArticle as any).authors.name}</span>}
                {(editorArticle as any).published_at && (
                  <time datetime={(editorArticle as any).published_at}>
                    {format(new Date((editorArticle as any).published_at), 'MMM d, yyyy')}
                  </time>
                )}
                {(editorArticle as any).reading_time_minutes && <span>{(editorArticle as any).reading_time_minutes} min read</span>}
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- Trending -->
    {trendingArticles && trendingArticles.length > 0 && (
      <section class="py-8 border-t border-border/30">
        <div class="container mx-auto px-4 mb-4">
          <h2 class="font-display text-xl font-bold flex items-center gap-2">
            🔥 <span>Trending</span>
          </h2>
        </div>
        <div class="flex gap-4 overflow-x-auto pr-4 pb-4 snap-x snap-mandatory" style="padding-left:max(1rem, calc((100vw - 1400px) / 2 + 1rem));scroll-padding-left:max(1rem, calc((100vw - 1400px) / 2 + 1rem));-ms-overflow-style:none;scrollbar-width:none;">
          {trendingArticles.map((article: any) => {
            const catColor = getCategoryColor(article.categories?.slug || '');
            return (
              <a
                href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                class="group flex-none w-[220px] snap-start rounded-xl overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                style={`border-top:3px solid ${catColor}`}
              >
                {article.featured_image_url ? (
                  <img
                    src={getOptimizedThumbnail(article.featured_image_url)}
                    alt={article.title}
                    class="w-full h-32 object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-32" style={`background:${catColor}18`} />
                )}
                <div class="p-3">
                  {article.categories && (
                    <span
                      class="inline-block px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide text-white mb-1.5 w-fit"
                      style={`background-color:${catColor}`}
                    >
                      {article.categories.name}
                    </span>
                  )}
                  <h3 class="text-[13px] font-semibold leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200">{article.title}</h3>
                  {article.reading_time_minutes && (
                    <p class="text-[11px] text-muted-foreground mt-1.5">{article.reading_time_minutes} min read</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Below-fold interactive sections (Recommended, Events, Newsletter CTA) -->
    <HomeSectionsIsland
      client:only="react"
      supabaseUrl={siteConfig.supabaseUrl}
      supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
    />

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-hero {
    position: relative;
    min-height: 65vh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    border-radius: 0.5rem;
    background: hsl(var(--muted));
  }
  @media (max-width: 768px) {
    .article-hero {
      min-height: 60vh;
    }
  }
  .article-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(4,4,5,0.95) 0%, rgba(4,4,5,0.7) 40%, rgba(4,4,5,0.2) 70%, transparent 100%);
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .article-hero-gradient {
      background: linear-gradient(to top, rgba(4,4,5,0.97) 0%, rgba(4,4,5,0.8) 50%, rgba(4,4,5,0.3) 75%, transparent 100%);
    }
  }
  .article-hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 2rem;
  }
  @media (max-width: 768px) {
    .article-hero-content {
      padding: 1.25rem;
    }
  }
  .article-hero-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: white;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }
  .article-hero-excerpt {
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }
</style>
