---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const { data: companies } = await supabase
  .from('ai_companies')
  .select('id, name, slug, description, logo_url, website_url, country, city, category, funding_stage, is_featured, is_verified')
  .order('is_featured', { ascending: false })
  .order('name', { ascending: true })
  .limit(200);

const allCompanies = (companies || []) as any[];

// Build unique country list for filter
const countries = [...new Set(allCompanies.map((c: any) => c.country).filter(Boolean))].sort() as string[];
---

<BaseLayout
  title={`AI Companies Directory — ${siteConfig.name}`}
  description="Directory of AI companies, startups, and research labs across Asia."
  canonical={`${siteConfig.url}/directory`}
>
  <SiteHeader currentPath="/directory" />
  <main id="main-content">
    <div class="border-b border-border/40" style="border-top:4px solid hsl(var(--primary))">
      <div class="container mx-auto px-4 py-8 flex flex-col sm:flex-row sm:items-end gap-4 justify-between">
        <div>
          <h1 class="text-3xl font-bold">AI Companies Directory</h1>
          <p class="text-muted-foreground mt-1 max-w-xl">Explore the AI companies, startups, and research labs shaping Asia's future.</p>
        </div>
        <p class="text-sm text-muted-foreground shrink-0">{allCompanies.length} companies</p>
      </div>
    </div>

    <!-- Country filter -->
    {countries.length > 1 && (
      <div class="border-b border-border/30">
        <div class="container mx-auto px-4 py-3 flex flex-wrap gap-2 items-center">
          <button
            class="country-filter px-3 py-1 text-xs font-semibold rounded-full border border-primary bg-primary text-white transition-all"
            data-country="all"
          >All</button>
          {countries.map((c: string) => (
            <button
              class="country-filter px-3 py-1 text-xs font-medium rounded-full border border-border text-muted-foreground hover:border-primary/50 hover:text-foreground transition-all"
              data-country={c}
            >{c}</button>
          ))}
        </div>
      </div>
    )}

    <section class="container mx-auto px-4 py-8">
      {allCompanies.length === 0 ? (
        <p class="text-center text-muted-foreground py-12">No companies found — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="companies-grid">
          {allCompanies.map((company: any) => {
            const cats = Array.isArray(company.category) ? company.category : (company.category ? [company.category] : []);
            return (
              <a
                href={company.website_url || '#'}
                target="_blank"
                rel="noopener noreferrer"
                class="company-card group block rounded-xl border border-border bg-card p-5 hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                style="border-left:4px solid hsl(var(--primary));box-shadow:var(--shadow-card)"
                data-country={company.country || ''}
              >
                <div class="flex items-center gap-3 mb-3">
                  {company.logo_url ? (
                    <img src={company.logo_url} alt={`${company.name} logo`} class="w-10 h-10 rounded-lg object-contain bg-muted/40 p-1 shrink-0" loading="lazy" />
                  ) : (
                    <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                      <span class="text-sm font-bold text-primary">{company.name.charAt(0)}</span>
                    </div>
                  )}
                  <div class="min-w-0">
                    <h2 class="font-bold text-sm leading-tight group-hover:text-primary transition-colors duration-200 truncate">{company.name}</h2>
                    {(company.city || company.country) && (
                      <p class="text-[11px] text-muted-foreground truncate">{[company.city, company.country].filter(Boolean).join(', ')}</p>
                    )}
                  </div>
                  {company.is_verified && (
                    <svg class="w-4 h-4 text-primary shrink-0 ml-auto" viewBox="0 0 24 24" fill="currentColor"><path d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-.503 3.338 3.745 3.745 0 0 1-3.338.503A3.745 3.745 0 0 1 12 21a3.745 3.745 0 0 1-3.065-1.591 3.745 3.745 0 0 1-3.338-.503 3.745 3.745 0 0 1-.504-3.338A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 .504-3.338 3.745 3.745 0 0 1 3.338-.503A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.338.504 3.746 3.746 0 0 1 .503 3.338A3.745 3.745 0 0 1 21 12Z"/></svg>
                  )}
                </div>
                {company.description && (
                  <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{company.description}</p>
                )}
                {cats.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-auto">
                    {cats.slice(0, 2).map((cat: string) => (
                      <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-muted/60 text-muted-foreground">{cat}</span>
                    ))}
                    {cats.length > 2 && (
                      <span class="px-1.5 py-0.5 rounded text-[10px] text-muted-foreground">+{cats.length - 2}</span>
                    )}
                  </div>
                )}
                {company.funding_stage && (
                  <p class="text-[10px] text-muted-foreground mt-2 font-medium">{company.funding_stage}</p>
                )}
              </a>
            );
          })}
        </div>
      )}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.country-filter');
  const cards = document.querySelectorAll<HTMLElement>('.company-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const country = btn.dataset.country || 'all';
      filterBtns.forEach(b => {
        const active = b.dataset.country === country;
        b.className = `country-filter px-3 py-1 text-xs font-${active ? 'semibold' : 'medium'} rounded-full border ${active ? 'border-primary bg-primary text-white' : 'border-border text-muted-foreground hover:border-primary/50 hover:text-foreground'} transition-all`;
      });
      cards.forEach(card => {
        const show = country === 'all' || card.dataset.country === country;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>
