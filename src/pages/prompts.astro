---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
  title={`AI Prompts — ${siteConfig.name}`}
  description="Ready-to-use AI prompts for ChatGPT, Claude, Gemini, and more — curated for Asia."
  canonical={`${siteConfig.url}/prompts`}
>
  <SiteHeader currentPath="/prompts" />
  <main id="main-content">
    <div class="border-b border-border/40" style="border-top:4px solid hsl(var(--primary))">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold">AI Prompts</h1>
        <p class="text-muted-foreground mt-1 max-w-xl">Ready-to-use prompts for ChatGPT, Claude, Gemini, and more — built for professionals in Asia.</p>
      </div>
    </div>

    <section class="container mx-auto px-4 py-16">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5" style="background-color:hsl(var(--primary)/0.1)">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="1.5"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <h2 class="text-xl font-bold mb-3">Prompts library coming soon</h2>
        <p class="text-muted-foreground text-sm leading-relaxed mb-6">
          We're curating a library of high-quality prompts for business, creativity, research, and more.
          Subscribe to be notified when it launches.
        </p>
        <a
          href="/newsletter"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-white transition-opacity hover:opacity-90"
          style="background-color:hsl(var(--primary))"
        >
          Get notified when it launches
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
