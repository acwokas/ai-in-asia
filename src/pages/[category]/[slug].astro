---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { siteConfig } from '../../site.config';
import { getCategoryColor } from '../../lib/categoryColors';
import { getOptimizedHeroImage, getOptimizedAvatar } from '../../lib/imageOptimization';
import { fixEncoding } from '../../lib/textUtils';
import { calculateReadingTime } from '../../lib/readingTime';
import { format } from 'date-fns';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ArticleReactionsIsland from '../../components/islands/ArticleReactionsIsland';
import CommentsIsland from '../../components/islands/CommentsIsland';
import NewsletterIsland from '../../components/islands/NewsletterIsland';
import ThreeBeforeNineIsland from '../../components/islands/ThreeBeforeNineIsland';
import { generateHTML } from '@tiptap/core';
import StarterKit from '@tiptap/starter-kit';
import Link from '@tiptap/extension-link';
import { Table, TableRow, TableHeader, TableCell } from '@tiptap/extension-table';
import TextAlign from '@tiptap/extension-text-align';
import Underline from '@tiptap/extension-underline';
import { ImageFigure } from '../../components/tiptap/extensions/ImageFigure';
import { YouTubeEmbed } from '../../components/tiptap/extensions/YouTubeEmbed';
import { PromptBox } from '../../components/tiptap/extensions/PromptBox';
import { SocialEmbed } from '../../components/tiptap/extensions/SocialEmbed';
import { renderArticleContentHtml, addTargetBlankToExternalLinks, addNofollowToExternalLinks, injectAiTermTooltips, type GlossaryTerm } from '../../lib/articleRenderer';

export const prerender = false;

const { category, slug } = Astro.params as { category: string; slug: string };

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const { data: article } = await supabase
  .from('articles')
  .select(`
    *,
    authors!articles_author_id_fkey (id, name, slug, bio, avatar_url, job_title, twitter_handle),
    categories!articles_primary_category_id_fkey (name, slug, id)
  `)
  .eq('slug', slug)
  .eq('status', 'published')
  .maybeSingle();

if (!article) {
  return Astro.redirect('/404', 301);
}

const catSlug = (article as any).categories?.slug;
if (catSlug && catSlug !== category) {
  return Astro.redirect(`/${catSlug}/${slug}`, 301);
}

const author = (article as any).authors;
const cat = (article as any).categories;
const heroImage = article.og_image_url || article.featured_image_url;

// Fetch related articles for right rail "More in [category]"
const relatedArticles = cat?.id ? (await supabase
  .from('articles')
  .select('id, title, slug, featured_image_url, reading_time_minutes, published_at')
  .eq('status', 'published')
  .eq('primary_category_id', cat.id)
  .neq('id', article.id)
  .order('published_at', { ascending: false, nullsFirst: false })
  .limit(5)
).data || [] : [];
const readingTime = article.reading_time_minutes || calculateReadingTime(article.content, article.title || '');
const canonicalUrl = `${siteConfig.url}/${catSlug || category}/${slug}`;
const titleClean = fixEncoding(article.title || '');
const isSponsored = !!(article as any).is_sponsored;
const authorName = author?.name || siteConfig.defaultAuthor;

// TL;DR snapshot
const snap = (article as any).tldr_snapshot;
let tldrBullets: string[] = [];
let tldrWhoShouldPayAttention: string | undefined;
let tldrWhatChangesNext: string | undefined;
if (typeof snap === 'string' && snap.trim()) {
  tldrBullets = snap.trim()
    .split(/\.\s+/)
    .filter((s: string) => s.trim().length > 10)
    .map((s: string, i: number, arr: string[]) => s.trim() + (i < arr.length - 1 || !s.trim().endsWith('.') ? '.' : ''));
  if (tldrBullets.length === 0) tldrBullets = [snap.trim()];
} else if (typeof snap === 'object' && snap !== null) {
  tldrBullets = (snap as any).bullets || [];
  tldrWhoShouldPayAttention = (snap as any).whoShouldPayAttention;
  tldrWhatChangesNext = (snap as any).whatChangesNext;
}

// Fetch glossary terms for AI term tooltips
const aiTags: string[] = (article as any).ai_tags || [];
let glossaryTerms: GlossaryTerm[] = [];
if (aiTags.length > 0) {
  const { data: termsData } = await supabase
    .from('glossary_terms')
    .select('term, definition')
    .in('term', aiTags)
    .limit(20);
  glossaryTerms = (termsData || []) as GlossaryTerm[];
}

// 3 Before 9 audio support
const articleType = (article as any).article_type;
const snapObj = (typeof snap === 'object' && snap !== null) ? snap as any : null;
const audioUrl: string | null =
  (article as any).podcast_audio_url ||
  snapObj?.audioEnglish ||
  snapObj?.audio?.en ||
  null;
const isThreeBeforeNine = articleType === 'three_before_nine';
const showAudioPlayer = isThreeBeforeNine && !!audioUrl;

// FAQ
interface FaqItem { question: string; answer: string }
const faqs: FaqItem[] = Array.isArray(snapObj?.faqs) ? snapObj.faqs as FaqItem[] : [];

// Render content
const tiptapExtensions = [
  StarterKit,
  Link.configure({ openOnClick: false }),
  Table.configure({ resizable: false }),
  TableRow,
  TableHeader,
  TableCell,
  TextAlign.configure({ types: ['heading', 'paragraph'] }),
  Underline,
  ImageFigure,
  YouTubeEmbed,
  PromptBox,
  SocialEmbed,
];

let contentHtml = '';
try {
  if (typeof article.content === 'string') {
    contentHtml = renderArticleContentHtml(article.content, isSponsored);
  } else if (article.content && typeof article.content === 'object') {
    contentHtml = generateHTML(article.content as any, tiptapExtensions);
    contentHtml = addTargetBlankToExternalLinks(contentHtml);
    if (isSponsored) contentHtml = addNofollowToExternalLinks(contentHtml);
  }
} catch {
  contentHtml = typeof article.content === 'string' ? article.content : '';
}
if (glossaryTerms.length > 0 && contentHtml) {
  contentHtml = injectAiTermTooltips(contentHtml, glossaryTerms);
}

// JSON-LD
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: titleClean,
  description: article.meta_description || article.excerpt || '',
  ...(heroImage ? { image: [heroImage] } : {}),
  datePublished: article.published_at,
  dateModified: article.updated_at || article.published_at,
  author: {
    '@type': 'Person',
    name: authorName,
    ...(author?.slug ? { url: `${siteConfig.url}/author/${author.slug}` } : {}),
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    logo: { '@type': 'ImageObject', url: `${siteConfig.url}/favicon.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(cat ? { articleSection: cat.name } : {}),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    ...(cat ? [{ '@type': 'ListItem', position: 2, name: cat.name, item: `${siteConfig.url}/${cat.slug}` }] : []),
    { '@type': 'ListItem', position: cat ? 3 : 2, name: titleClean, item: canonicalUrl },
  ],
};

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;

// Table of Contents — extract h2/h3 from rendered content and inject IDs
interface TocEntry { id: string; text: string; level: 2 | 3 }
const tocEntries: TocEntry[] = [];
if (contentHtml) {
  let slugCounts: Record<string, number> = {};
  contentHtml = contentHtml.replace(/<(h[23])([^>]*)>([\s\S]*?)<\/h[23]>/gi, (_match: string, tag: string, attrs: string, inner: string) => {
    const level = parseInt(tag[1], 10) as 2 | 3;
    const text = inner.replace(/<[^>]+>/g, '').trim();
    const base = text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').slice(0, 60);
    slugCounts[base] = (slugCounts[base] || 0) + 1;
    const id = slugCounts[base] > 1 ? `${base}-${slugCounts[base]}` : base;
    tocEntries.push({ id, text, level });
    return `<${tag}${attrs} id="${id}">${inner}</${tag}>`;
  });
}

// Share URLs
const shareUrl = encodeURIComponent(canonicalUrl);
const shareTitle = encodeURIComponent(titleClean);
const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(titleClean + ' ' + canonicalUrl)}`;
const twitterUrl = `https://x.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
const emailUrl = `mailto:?subject=${shareTitle}&body=${shareUrl}`;
---

<BaseLayout
  title={titleClean}
  description={article.meta_description || article.excerpt || undefined}
  ogImage={heroImage || undefined}
  ogType="article"
  canonical={canonicalUrl}
  noIndex={false}
  jsonLd={[articleJsonLd, breadcrumbJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])]}
  publishedTime={article.published_at || undefined}
  modifiedTime={article.updated_at || undefined}
  authorName={authorName}
>
  <SiteHeader />

  {isThreeBeforeNine ? (
    <main id="main-content">
      {/* Full-bleed hero */}
      {heroImage && (
        <div class="relative w-full overflow-hidden bg-muted" style="height:520px;max-height:65vw">
          <img
            src={getOptimizedHeroImage(heroImage)}
            alt={titleClean}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(to bottom,rgba(0,0,0,0.15) 0%,rgba(0,0,0,0.7) 100%)"></div>
          <div class="absolute bottom-0 left-0 right-0 px-6 pb-8 max-w-3xl mx-auto">
            <span class="inline-block px-3 py-1 rounded text-xs font-bold uppercase tracking-wide text-white mb-3" style="background-color:#5F72FF">3 Before 9</span>
            {article.published_at && (
              <p class="text-sm font-semibold text-white/80 mb-2">
                {format(new Date(article.published_at as string), 'EEEE, d MMMM yyyy')}
              </p>
            )}
            <h1 class="text-3xl md:text-4xl font-display font-bold leading-tight text-white mb-2">{titleClean}</h1>
            {article.excerpt && <p class="text-base text-white/80 leading-relaxed line-clamp-2">{article.excerpt}</p>}
          </div>
        </div>
      )}

      <div class="max-w-3xl mx-auto px-6 py-6">
        <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-1.5 text-xs text-muted-foreground mb-4">
          <a href="/" class="hover:text-foreground transition-colors">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/news/3-before-9" class="hover:text-foreground transition-colors">3 Before 9</a>
          <span aria-hidden="true">/</span>
          <span class="truncate max-w-[240px]">{titleClean}</span>
        </nav>

        {/* Show title/strapline only if there was no hero (hero already shows them) */}
        {!heroImage && (
          <div class="mb-5">
            {article.published_at && (
              <p class="text-sm font-semibold mb-2" style="color:#5F72FF">
                {format(new Date(article.published_at as string), 'EEEE, d MMMM yyyy')}
              </p>
            )}
            <h1 class="text-3xl md:text-4xl font-display font-bold leading-tight mb-3">{titleClean}</h1>
            {article.excerpt && <p class="text-lg text-muted-foreground leading-relaxed">{article.excerpt}</p>}
          </div>
        )}

        <!-- Spotify player -->
        {isThreeBeforeNine && (
          <div class="mb-6">
            <iframe
              src={`${snapObj?.spotifyEpisodeUrl || 'https://open.spotify.com/embed/show/3aHz4AvuZTHjiKJaZ9FUdW'}?utm_source=generator&theme=0`}
              width="100%"
              height="80"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
              style="border: none; border-radius: 12px;"
              title="3 Before 9 on Spotify"
            ></iframe>
          </div>
        )}

        <!-- Who / What sections from TL;DR snapshot -->
        {(tldrWhoShouldPayAttention || tldrWhatChangesNext) && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            {tldrWhoShouldPayAttention && (
              <div class="rounded-xl border border-border/50 bg-card p-4">
                <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color:#5F72FF">Who should pay attention</p>
                <p class="text-sm leading-relaxed">{tldrWhoShouldPayAttention}</p>
              </div>
            )}
            {tldrWhatChangesNext && (
              <div class="rounded-xl border border-border/50 bg-card p-4">
                <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color:#5F72FF">What changes next</p>
                <p class="text-sm leading-relaxed">{tldrWhatChangesNext}</p>
              </div>
            )}
          </div>
        )}

        <!-- Article body content (editorial view, closing thoughts, etc.) -->
        {contentHtml && (
          <div class="prose prose-lg max-w-none article-content mb-6" set:html={contentHtml} />
        )}

        <!-- Share -->
        <div class="flex flex-wrap items-center gap-2 py-6 border-y border-border/40">
          <span class="text-xs text-muted-foreground mr-1">Share this edition:</span>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
            style="background:#25D366;color:#fff">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp
          </a>
          <a href={twitterUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on X"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
            style="background:#000;color:#fff">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
            style="background:#0A66C2;color:#fff">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href={emailUrl} aria-label="Share via Email"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-80 transition-opacity"
            style="background:hsl(var(--muted));color:hsl(var(--muted-foreground))">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
        </div>
      </div>

      <!-- 3B9 island: signals, newsletter, recent editions -->
      <ThreeBeforeNineIsland
        client:only="react"
        article={article}
        audioUrl={audioUrl}
        canonicalUrl={canonicalUrl}
        supabaseUrl={siteConfig.supabaseUrl}
        supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
      />
    </main>
  ) : (
  <main id="main-content">
    {heroImage && (
      <div class="relative w-full overflow-hidden bg-muted" style="height:520px;max-height:65vw">
        <img
          src={getOptimizedHeroImage(heroImage)}
          alt={titleClean}
          class="w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 55%)"></div>
        {cat && (
          <div class="absolute bottom-5 left-5">
            <a
              href={`/${cat.slug}`}
              class="inline-block px-3 py-1 rounded text-xs font-bold uppercase tracking-wide text-white hover:opacity-90 transition-opacity"
              style={`background-color:${getCategoryColor(cat.slug)}`}
            >
              {cat.name}
            </a>
          </div>
        )}
      </div>
    )}

    <div class="container mx-auto px-4 py-8 max-w-[1100px]">

      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-1.5 text-xs text-muted-foreground mb-6">
        <a href="/" class="hover:text-foreground transition-colors">Home</a>
        {cat && (
          <>
            <span aria-hidden="true">/</span>
            <a href={`/${cat.slug}`} class="hover:text-foreground transition-colors">{cat.name}</a>
          </>
        )}
        <span aria-hidden="true">/</span>
        <span class="truncate max-w-[240px]">{titleClean}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">
        <article>
          <header class="mb-6">
            {cat && !heroImage && (
              <a
                href={`/${cat.slug}`}
                class="inline-block px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wide text-white mb-3 hover:opacity-90 transition-opacity"
                style={`background-color:${getCategoryColor(cat.slug)}`}
              >
                {cat.name}
              </a>
            )}

            <h1 class="text-3xl md:text-4xl font-display font-bold leading-tight mb-4">{titleClean}</h1>

            {article.excerpt && (
              <p class="text-lg text-muted-foreground leading-relaxed mb-5">{article.excerpt}</p>
            )}

            <!-- Byline -->
            <div class="flex flex-wrap items-center gap-4 py-4 border-y border-border/40">
              <a href={author?.slug ? `/author/${author.slug}` : '#'} class="flex items-center gap-2.5 hover:underline">
                {author?.avatar_url ? (
                  <img
                    src={getOptimizedAvatar(author.avatar_url)}
                    alt={authorName}
                    class="w-9 h-9 rounded-full object-cover ring-2 ring-border"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-9 h-9 rounded-full bg-muted flex items-center justify-center text-sm font-bold">
                    {authorName.charAt(0)}
                  </div>
                )}
                <div>
                  <div class="text-sm font-semibold">{authorName}</div>
                  {author?.job_title && <div class="text-xs text-muted-foreground">{author.job_title}</div>}
                </div>
              </a>
              <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground ml-auto">
                {article.published_at && (
                  <time datetime={article.published_at}>
                    {format(new Date(article.published_at), 'MMMM d, yyyy')}
                  </time>
                )}
                {article.updated_at && article.updated_at !== article.published_at && (
                  <span class="text-muted-foreground/60">
                    · Updated {format(new Date(article.updated_at), 'MMM d, yyyy')}
                  </span>
                )}
                {readingTime && <span>{readingTime} min read</span>}
              </div>
            </div>

            <!-- Share -->
            <div class="flex flex-wrap items-center gap-2 pt-4">
              <span class="text-xs text-muted-foreground mr-1">Share:</span>
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
                style="background:#25D366;color:#fff">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                WhatsApp
              </a>
              <a href={twitterUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on X"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
                style="background:#000;color:#fff">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X
              </a>
              <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-90 transition-opacity"
                style="background:#0A66C2;color:#fff">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href={emailUrl} aria-label="Share via Email"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium hover:opacity-80 transition-opacity"
                style="background:hsl(var(--muted));color:hsl(var(--muted-foreground))">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                Email
              </a>
            </div>
          </header>

          <!-- TL;DR Snapshot — amber/gold accent -->
          {tldrBullets.length > 0 && (
            <div class="tldr-snapshot my-8 rounded-xl" style="background: hsl(225, 22%, 7%); border: 1.5px solid rgba(245,158,11,0.4);">
              <div class="px-6 pt-5 pb-3">
                <div class="flex items-center gap-2 mb-1">
                  <span style="font-size:1.25rem;line-height:1;">⚡</span>
                  <span class="font-bold text-xl" style="color:#F59E0B;">AI Snapshot</span>
                </div>
                <p class="text-sm italic" style="color:rgba(245,158,11,0.65);">The TL;DR: what matters, fast.</p>
              </div>
              <div class="px-6 pb-5 space-y-2.5">
                {tldrBullets.map((bullet: string) => (
                  <div class="flex gap-3">
                    <div class="flex-shrink-0 mt-2">
                      <div class="w-1.5 h-1.5 rounded-full" style="background:#F59E0B;"></div>
                    </div>
                    <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.88);">{bullet}</p>
                  </div>
                ))}
                {(tldrWhoShouldPayAttention || tldrWhatChangesNext) && (
                  <div class="pt-3 mt-3 space-y-2" style="border-top:1px solid rgba(245,158,11,0.2);">
                    {tldrWhoShouldPayAttention && (
                      <p class="text-sm" style="color:rgba(255,255,255,0.75);">
                        <span class="font-semibold" style="color:rgba(255,255,255,0.9);">Who should pay attention:</span>{' '}
                        {tldrWhoShouldPayAttention}
                      </p>
                    )}
                    {tldrWhatChangesNext && (
                      <p class="text-sm" style="color:rgba(255,255,255,0.75);">
                        <span class="font-semibold" style="color:rgba(255,255,255,0.9);">What changes next:</span>{' '}
                        {tldrWhatChangesNext}
                      </p>
                    )}
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Article content -->
          <div class="prose prose-lg max-w-none article-content" set:html={contentHtml} />

          <!-- FAQ -->
          {faqs.length > 0 && (
            <div class="mt-10">
              <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
              <div class="space-y-2">
                {faqs.map((faq) => (
                  <details class="group border border-border rounded-lg overflow-hidden">
                    <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer font-semibold text-sm list-none select-none hover:bg-muted/40 transition-colors">
                      <span>{faq.question}</span>
                      <svg class="w-4 h-4 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </summary>
                    <div class="px-5 pb-5 pt-1 text-sm text-muted-foreground leading-relaxed border-t border-border/40">
                      {faq.answer}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- AI Terms in This Article -->
          {glossaryTerms.length > 0 && (
            <div class="mt-10 pt-6 border-t border-border/40">
              <h3 class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#F59E0B;">AI Terms in This Article</h3>
              <div class="space-y-1.5">
                {glossaryTerms.map((gt) => (
                  <details class="group border border-border/50 rounded-lg overflow-hidden">
                    <summary class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer list-none select-none hover:bg-muted/30 transition-colors">
                      <span class="text-sm font-semibold" style="color:#F59E0B;text-decoration:underline;text-decoration-style:dotted;text-underline-offset:3px;">{gt.term}</span>
                      <svg class="w-3.5 h-3.5 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </summary>
                    <div class="px-4 pb-3 pt-1 text-sm text-muted-foreground leading-relaxed border-t border-border/30">
                      {gt.definition}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- Author bio -->
          {author?.bio && (
            <div class="mt-10 p-6 rounded-xl border border-border/50 bg-muted/20">
              <div class="flex items-start gap-4">
                {author.avatar_url ? (
                  <img
                    src={getOptimizedAvatar(author.avatar_url)}
                    alt={authorName}
                    class="w-14 h-14 rounded-full object-cover shrink-0"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-14 h-14 rounded-full bg-muted flex items-center justify-center text-xl font-bold shrink-0">
                    {authorName.charAt(0)}
                  </div>
                )}
                <div>
                  <a href={`/author/${author.slug}`} class="font-display font-bold text-base hover:underline">{authorName}</a>
                  {author.job_title && <p class="text-xs text-muted-foreground mb-2">{author.job_title}</p>}
                  <p class="text-sm text-muted-foreground leading-relaxed">{author.bio}</p>
                </div>
              </div>
            </div>
          )}

          <!-- Reactions -->
          <ArticleReactionsIsland
            client:only="react"
            articleId={article.id}
            supabaseUrl={siteConfig.supabaseUrl}
            supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
          />

          <!-- Comments -->
          <CommentsIsland
            client:only="react"
            articleId={article.id}
            supabaseUrl={siteConfig.supabaseUrl}
            supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
          />

          <!-- Back to category -->
          {cat && (
            <div class="mt-10 pt-6 border-t border-border/40">
              <a
                href={`/${cat.slug}`}
                class="inline-flex items-center gap-2 text-sm font-semibold hover:underline"
                style={`color:${getCategoryColor(cat.slug)}`}
              >
                More from {cat.name}
              </a>
            </div>
          )}
        </article>

        <!-- Sidebar / right rail -->
        <aside class="hidden lg:block">
          <div class="sticky top-20 space-y-6">

            <!-- Table of Contents -->
            {tocEntries.length >= 3 && (
              <nav aria-label="Table of contents" class="rounded-lg border border-border/50 bg-muted/10 p-4">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3">In this article</p>
                <ol class="space-y-1.5">
                  {tocEntries.map((entry) => (
                    <li class={entry.level === 3 ? 'pl-3' : ''}>
                      <a
                        href={`#${entry.id}`}
                        class="text-sm leading-snug text-muted-foreground hover:text-foreground transition-colors line-clamp-2"
                      >
                        {entry.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )}

            <!-- Newsletter CTA -->
            <NewsletterIsland
              client:only="react"
              variant="compact"
              supabaseUrl={siteConfig.supabaseUrl}
              supabaseAnonKey={import.meta.env.SUPABASE_ANON_KEY || siteConfig.supabaseAnonKey}
            />

            <!-- Ad slot -->
            <div class="rounded-lg border border-dashed border-border/40 bg-muted/10 flex items-center justify-center min-h-[250px] text-xs text-muted-foreground/40 select-none">
              <ins
                class="adsbygoogle"
                style="display:block"
                data-ad-client={siteConfig.adsensePubId}
                data-ad-slot="7654321"
                data-ad-format="auto"
                data-full-width-responsive="true"
              ></ins>
              <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            </div>

            <!-- More in [category] -->
            {cat && relatedArticles.length > 0 && (
              <div>
                <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3">
                  More in {cat.name}
                </h3>
                <div class="space-y-3">
                  {(relatedArticles as any[]).map((rel) => (
                    <a
                      href={`/${cat.slug}/${rel.slug}`}
                      class="group flex gap-3 items-start hover:bg-muted/30 rounded-lg p-2 -mx-2 transition-colors"
                    >
                      {rel.featured_image_url && (
                        <img
                          src={rel.featured_image_url}
                          alt={rel.title}
                          class="w-16 h-12 object-cover rounded shrink-0"
                          loading="lazy"
                        />
                      )}
                      <div class="min-w-0">
                        <p class="text-sm font-medium leading-snug line-clamp-2 group-hover:underline">{rel.title}</p>
                        {rel.reading_time_minutes && (
                          <p class="text-xs text-muted-foreground mt-0.5">{rel.reading_time_minutes} min read</p>
                        )}
                      </div>
                    </a>
                  ))}
                  <a href={`/${cat.slug}`} class="block text-xs font-semibold hover:underline mt-2" style={`color:${getCategoryColor(cat.slug)}`}>
                    View all {cat.name} →
                  </a>
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>
  </main>
  )}

  <SiteFooter />
</BaseLayout>
