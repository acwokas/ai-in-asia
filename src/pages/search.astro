---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';

const q = Astro.url.searchParams.get('q')?.trim() || '';

let results: any[] = [];
let searchError = false;

if (q.length >= 2) {
  const supabase = createServerClient(
    siteConfig.supabaseUrl,
    import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
  );
  const { data, error } = await supabase
    .from('articles')
    .select(`
      id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
      authors:author_id (name),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .or(`title.ilike.%${q}%,excerpt.ilike.%${q}%`)
    .order('published_at', { ascending: false })
    .limit(24);

  if (!error) results = (data || []) as any[];
  else searchError = true;
}

const pageTitle = q ? `Search: "${q}" — ${siteConfig.name}` : `Search — ${siteConfig.name}`;
---

<BaseLayout title={pageTitle} description={`Search AI news and articles on ${siteConfig.name}.`} canonical={`${siteConfig.url}/search`}>
  <SiteHeader />
  <main id="main-content">
    <div class="border-b border-border/40">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-6">Search</h1>
        <form method="get" action="/search" class="flex gap-2 max-w-2xl">
          <input
            type="text"
            name="q"
            value={q}
            placeholder="Search articles, topics, companies…"
            autofocus
            class="flex-1 px-4 py-2.5 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 transition-shadow"
          />
          <button
            type="submit"
            class="px-5 py-2.5 rounded-lg font-semibold text-white transition-opacity hover:opacity-90"
            style="background-color:hsl(var(--primary))"
          >
            Search
          </button>
        </form>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      {q.length < 2 && (
        <p class="text-muted-foreground text-sm">Enter at least 2 characters to search.</p>
      )}
      {q.length >= 2 && searchError && (
        <p class="text-muted-foreground text-sm">Search unavailable — please try again.</p>
      )}
      {q.length >= 2 && !searchError && results.length === 0 && (
        <p class="text-muted-foreground text-sm">No results for <strong>"{q}"</strong>. Try different keywords.</p>
      )}
      {results.length > 0 && (
        <>
          <p class="text-sm text-muted-foreground mb-6">{results.length} result{results.length !== 1 ? 's' : ''} for <strong>"{q}"</strong></p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {results.map((article: any) => {
              const catColor = getCategoryColor(article.categories?.slug || '');
              return (
                <a
                  href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                  class="group block rounded-lg overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                  style={`border-left:4px solid ${catColor};box-shadow:var(--shadow-card)`}
                >
                  {article.featured_image_url ? (
                    <img
                      src={getOptimizedThumbnail(article.featured_image_url)}
                      alt={article.title}
                      class="w-full h-40 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-40" style={`background:${catColor}15`} />
                  )}
                  <div class="p-4">
                    {article.categories && (
                      <span
                        class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white mb-2"
                        style={`background-color:${catColor}`}
                      >
                        {article.categories.name}
                      </span>
                    )}
                    <h3 class="font-semibold text-sm leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200 mb-2">{article.title}</h3>
                    {article.excerpt && (
                      <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{article.excerpt}</p>
                    )}
                    <div class="flex items-center gap-2 text-xs text-muted-foreground">
                      {article.authors && <span>{article.authors.name}</span>}
                      {article.published_at && (
                        <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                      )}
                      {article.reading_time_minutes && <span>· {article.reading_time_minutes} min</span>}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      )}
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
