---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getCategoryColor } from '../lib/categoryColors';
import { getOptimizedThumbnail } from '../lib/imageOptimization';
import { format } from 'date-fns';

const PAGE_SIZE = 24;
const pageParam = Astro.url.searchParams.get('page');
const page = Math.max(1, parseInt(pageParam || '1', 10));
const offset = (page - 1) * PAGE_SIZE;

const supabase = createServerClient(
  siteConfig.supabaseUrl,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY || siteConfig.supabaseAnonKey,
);

const [articlesRes, countRes] = await Promise.all([
  supabase
    .from('articles')
    .select(`
      id, title, slug, excerpt, featured_image_url, reading_time_minutes, published_at,
      authors:author_id (name),
      categories:primary_category_id (name, slug)
    `)
    .eq('status', 'published')
    .order('published_at', { ascending: false, nullsFirst: false })
    .range(offset, offset + PAGE_SIZE - 1),

  supabase
    .from('articles')
    .select('id', { count: 'exact', head: true })
    .eq('status', 'published'),
]);

const articles = (articlesRes.data || []) as any[];
const totalCount = countRes.count ?? 0;
const totalPages = Math.ceil(totalCount / PAGE_SIZE);

const pageTitle = page > 1
  ? `All Articles — Page ${page} | ${siteConfig.name}`
  : `All Articles | ${siteConfig.name}`;
---

<BaseLayout
  title={pageTitle}
  description={`Browse all ${totalCount.toLocaleString()} AI articles from across Asia.`}
  canonical={page > 1 ? `${siteConfig.url}/articles?page=${page}` : `${siteConfig.url}/articles`}
>
  <SiteHeader />
  <main id="main-content">
    <div class="border-b border-border/40">
      <div class="container mx-auto px-4 py-8">
        <div class="flex items-end gap-4">
          <div>
            <h1 class="text-3xl font-bold">All Articles</h1>
            <p class="text-muted-foreground mt-1">The latest AI news and analysis from across Asia</p>
          </div>
          {totalCount > 0 && (
            <div class="ml-auto text-right shrink-0">
              <span class="text-2xl font-black text-foreground">{totalCount.toLocaleString()}</span>
              <p class="text-xs text-muted-foreground">articles</p>
            </div>
          )}
        </div>
      </div>
    </div>

    <section class="container mx-auto px-4 py-8">
      {articles.length === 0 ? (
        <p class="text-center text-muted-foreground py-16">No articles yet — check back soon.</p>
      ) : (
        <>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {articles.map((article: any) => {
              const catColor = getCategoryColor(article.categories?.slug || '');
              return (
                <a
                  href={`/${article.categories?.slug || 'news'}/${article.slug}`}
                  class="group block rounded-lg overflow-hidden border border-border bg-card hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
                  style={`border-left:4px solid ${catColor};box-shadow:var(--shadow-card)`}
                >
                  {article.featured_image_url ? (
                    <img
                      src={getOptimizedThumbnail(article.featured_image_url)}
                      alt={article.title}
                      class="w-full h-44 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-44" style={`background:${catColor}15`} />
                  )}
                  <div class="p-4">
                    {article.categories && (
                      <span
                        class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide text-white mb-2"
                        style={`background-color:${catColor}`}
                      >
                        {article.categories.name}
                      </span>
                    )}
                    <h3 class="font-semibold text-sm leading-snug line-clamp-3 group-hover:text-primary transition-colors duration-200 mb-2">{article.title}</h3>
                    {article.excerpt && (
                      <p class="text-xs text-muted-foreground line-clamp-2 mb-3">{article.excerpt}</p>
                    )}
                    <div class="flex items-center gap-2 text-xs text-muted-foreground">
                      {article.authors && <span>{article.authors.name}</span>}
                      {article.published_at && (
                        <time datetime={article.published_at}>{format(new Date(article.published_at), 'MMM d, yyyy')}</time>
                      )}
                      {article.reading_time_minutes && <span>· {article.reading_time_minutes} min</span>}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          {totalPages > 1 && (
            <nav class="flex items-center justify-center gap-2 mt-10" aria-label="Pagination">
              {page > 1 && (
                <a
                  href={page === 2 ? '/articles' : `/articles?page=${page - 1}`}
                  class="px-4 py-2 rounded-lg border border-border text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
                >
                  Previous
                </a>
              )}
              <span class="text-sm text-muted-foreground px-2">Page {page} of {totalPages}</span>
              {page < totalPages && (
                <a
                  href={`/articles?page=${page + 1}`}
                  class="px-4 py-2 rounded-lg border border-border text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
                >
                  Next
                </a>
              )}
            </nav>
          )}
        </>
      )}
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
