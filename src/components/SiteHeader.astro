---
import { siteConfig } from '../site.config';
import SiteHeaderIsland from './islands/SiteHeaderIsland';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const NAV = [
  { href: '/news',     label: 'News' },
  { href: '/business', label: 'Business' },
  { href: '/life',     label: 'Life' },
  { href: '/learn',    label: 'Learn' },
  { href: '/create',   label: 'Create' },
  { href: '/voices',   label: 'Voices' },
];
---

<!-- Static SSR shell — hidden by island on mount -->
<div id="site-header-ssr" class="border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 sticky top-0 z-50">
  <div class="container mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <a href="/" class="shrink-0">
      <img src={siteConfig.logoUrl} alt={siteConfig.name} class="h-8 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-5 text-sm overflow-x-auto flex-1">
      {NAV.map(n => (
        <a
          href={n.href}
          class={`whitespace-nowrap transition-colors ${currentPath.startsWith(n.href) ? 'text-foreground font-semibold' : 'text-muted-foreground hover:text-foreground'}`}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a href="/search" class="p-2 rounded-full text-muted-foreground hover:text-foreground hover:bg-muted transition-colors" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </a>
      <a href="/newsletter" class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-primary text-primary-foreground hover:opacity-90 transition-opacity">
        Newsletter
      </a>
      <button id="mobile-menu-btn-ssr" class="lg:hidden p-2 rounded-full text-muted-foreground hover:text-foreground hover:bg-muted transition-colors" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- Island: mounts client-side, hides SSR shell, adds interactivity -->
<SiteHeaderIsland client:only="react" currentPath={currentPath} />
