---
import { siteConfig } from '../site.config';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');

const navItems = [
  { href: '/news',     label: 'News' },
  { href: '/business', label: 'Business' },
  { href: '/life',     label: 'Life' },
  { href: '/learn',    label: 'Learn' },
  { href: '/create',   label: 'Create' },
  { href: '/policy',   label: 'Policy' },
  { href: '/voices',   label: 'Voices' },
];

const toolsItems = [
  { href: '/tools',             label: 'All Tools',    desc: 'Browse all AI tools for Asia' },
  { href: '/guides',            label: 'Guides',       desc: 'Step-by-step AI guides for every skill level' },
  { href: '/events',            label: 'Events',       desc: 'AI conferences and meetups across Asia' },
  { href: '/tools/ai-glossary', label: 'AI Glossary',  desc: '470+ AI terms explained in plain language' },
  { href: '/ai-companies',      label: 'AI Companies', desc: 'Directory of AI companies across Asia' },
  { href: '/ai-policy-atlas',   label: 'Policy Atlas', desc: 'Track AI regulation across Asia-Pacific' },
  { href: '/prompts',           label: 'Prompts',      desc: 'Ready-to-use prompts for every platform' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container mx-auto px-4">
    <div class="flex h-16 items-center justify-between">

      <!-- Logo -->
      <div class="flex items-center gap-8">
        <a href="/" class="flex shrink-0 items-center group" aria-label={`${siteConfig.name} home`}>
          <img src={siteConfig.logoUrl} alt={siteConfig.name} width="240" height="44" style="height:44px;width:auto;max-width:none;" class="transition-opacity duration-200 group-hover:opacity-80" />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center space-x-1" aria-label="Primary navigation">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'text-sm font-medium tracking-wide uppercase px-3 py-1.5 border-b-2 transition-all duration-200 hover:text-primary hover:border-primary',
                isActive(href) ? 'text-primary border-primary' : 'border-transparent text-foreground/80'
              ]}
            >
              {label}
            </a>
          ))}

          <!-- Tools dropdown -->
          <div class="nav-dropdown relative" data-dropdown>
            <button
              class:list={[
                'text-sm font-medium tracking-wide uppercase px-3 py-1.5 border-b-2 transition-all duration-200 hover:text-primary hover:border-primary flex items-center gap-1 cursor-pointer select-none',
                toolsItems.some(t => isActive(t.href)) ? 'text-primary border-primary' : 'border-transparent text-foreground/80'
              ]}
              data-dropdown-trigger
              aria-haspopup="true"
              aria-expanded="false"
            >
              Tools
              <svg class="dropdown-chevron h-3 w-3 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-panel absolute left-0 top-full mt-1.5 hidden w-72 rounded-xl border border-border bg-background shadow-xl p-2 z-[60]">
              {toolsItems.map(({ href, label, desc }) => (
                <a href={href} class="flex items-start gap-3 w-full rounded-lg px-3 py-2.5 hover:bg-muted/80 transition-colors">
                  <div class="flex flex-col">
                    <span class="text-sm font-semibold text-foreground">{label}</span>
                    <span class="text-xs text-muted-foreground leading-snug">{desc}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </nav>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-1">
        <button
          id="search-toggle"
          aria-label="Search"
          class="flex h-10 w-10 items-center justify-center text-muted-foreground hover:text-foreground transition-colors rounded-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>

        <a
          href="/auth"
          aria-label="Sign in / Account"
          class="hidden md:flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </a>

        <a
          href="/newsletter"
          class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90"
          style="background-color:hsl(var(--primary))"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Newsletter
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="md:hidden flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        >
          <svg id="hamburger-icon" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg id="close-icon" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden border-t border-border/40"
    aria-label="Mobile navigation"
  >
    <div class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-background border-l border-border z-[70] overflow-y-auto pb-[env(safe-area-inset-bottom)] transition-transform duration-300 ease-out translate-x-full" id="mobile-panel">
      <div class="flex flex-col p-5">
        <div class="flex justify-between items-center mb-4">
          <span class="font-semibold text-lg">Menu</span>
          <button id="mobile-close" class="flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground hover:bg-muted transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>

        <button id="mobile-search-btn" class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg bg-muted/50 text-muted-foreground text-sm mb-5 hover:bg-muted transition-colors text-left">
          <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span>Search articles...</span>
        </button>

        <span class="text-xs uppercase tracking-wider text-muted-foreground font-semibold mb-2">Categories</span>
        <div class="flex flex-col space-y-1 mb-4">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-primary',
                isActive(href) ? 'text-primary' : 'text-foreground'
              ]}
            >
              {label}
            </a>
          ))}
          <span class="text-xs uppercase tracking-wider text-muted-foreground font-semibold pt-2 px-3">Tools</span>
          {toolsItems.map(({ href, label }) => (
            <a href={href} class="block rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-primary pl-5 text-muted-foreground">
              {label}
            </a>
          ))}
        </div>

        <div class="border-t border-border my-2" />
        <a href="/auth" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium hover:text-primary transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Sign In
        </a>
        <a href="/newsletter" class="mt-2 flex items-center justify-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90" style="background-color:hsl(var(--primary))">
          Subscribe to Newsletter
        </a>
      </div>
    </div>
    <!-- Backdrop -->
    <div id="mobile-backdrop" class="fixed inset-0 bg-background/60 backdrop-blur-sm z-[60] hidden"></div>
  </nav>
</header>

<!-- Search overlay -->
<div id="search-overlay" class="fixed inset-0 z-[200] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <div id="search-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="relative mx-auto mt-12 max-w-2xl px-4">
    <div class="rounded-xl border border-border bg-background shadow-2xl overflow-hidden">
      <div class="flex items-center gap-3 px-4 py-3 border-b border-border">
        <svg class="h-5 w-5 text-muted-foreground shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search AI in Asia..."
          autocomplete="off"
          class="flex-1 bg-transparent text-foreground placeholder:text-muted-foreground outline-none text-base"
        />
        <button id="search-close" class="flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors" aria-label="Close search">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div id="search-body" class="p-4 max-h-[60vh] overflow-y-auto">
        <div id="search-recent" class="hidden mb-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-2">Recent</p>
          <div id="search-recent-list" class="flex flex-wrap gap-2"></div>
        </div>
        <div id="search-popular">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-2">Popular</p>
          <div class="flex flex-wrap gap-2">
            {['ChatGPT', 'AI regulation', 'China AI', 'Singapore AI', 'LLM', 'AI jobs Asia', 'Japan AI', 'India AI'].map(term => (
              <button class="search-popular-chip px-3 py-1 rounded-full text-sm bg-muted hover:bg-primary hover:text-primary-foreground transition-colors" data-term={term}>{term}</button>
            ))}
          </div>
        </div>
        <div id="search-results" class="hidden space-y-1"></div>
        <div id="search-empty" class="hidden text-center py-8 text-muted-foreground text-sm">No results found for your search.</div>
      </div>
    </div>
    <p class="text-center text-xs text-white/50 mt-3">Press ESC to close</p>
  </div>
</div>
<div id="search-config" class="hidden" data-supabase-url={siteConfig.supabaseUrl} data-supabase-anon-key={siteConfig.supabaseAnonKey}></div>

<script>
  function initNav() {
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
      const trigger = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
      const panel = dropdown.querySelector<HTMLElement>('.dropdown-panel');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !panel.classList.contains('hidden');
        document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<SVGElement>('.dropdown-chevron').forEach(c => c.style.transform = '');
        document.querySelectorAll<HTMLButtonElement>('[data-dropdown-trigger]').forEach(t => t.setAttribute('aria-expanded', 'false'));
        if (!isOpen) {
          panel.classList.remove('hidden');
          const chevron = trigger.querySelector<SVGElement>('.dropdown-chevron');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    document.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<SVGElement>('.dropdown-chevron').forEach(c => c.style.transform = '');
      document.querySelectorAll<HTMLButtonElement>('[data-dropdown-trigger]').forEach(t => t.setAttribute('aria-expanded', 'false'));
    });

    const mobileToggle = document.getElementById('mobile-menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const mobilePanel = document.getElementById('mobile-panel');
    const mobileBackdrop = document.getElementById('mobile-backdrop');
    const mobileClose = document.getElementById('mobile-close');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIconEl = document.getElementById('close-icon');

    function openMobile() {
      mobileNav?.classList.remove('hidden');
      mobileBackdrop?.classList.remove('hidden');
      requestAnimationFrame(() => mobilePanel?.classList.replace('translate-x-full', 'translate-x-0'));
      mobileToggle?.setAttribute('aria-expanded', 'true');
      hamburgerIcon?.classList.add('hidden');
      closeIconEl?.classList.remove('hidden');
    }

    function closeMobile() {
      mobilePanel?.classList.replace('translate-x-0', 'translate-x-full');
      mobileBackdrop?.classList.add('hidden');
      setTimeout(() => mobileNav?.classList.add('hidden'), 300);
      mobileToggle?.setAttribute('aria-expanded', 'false');
      hamburgerIcon?.classList.remove('hidden');
      closeIconEl?.classList.add('hidden');
    }

    mobileToggle?.addEventListener('click', () => {
      if (mobileNav?.classList.contains('hidden')) openMobile(); else closeMobile();
    });
    mobileClose?.addEventListener('click', closeMobile);
    mobileBackdrop?.addEventListener('click', closeMobile);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
        closeMobile();
      }
    });
  }

  function initSearch() {
    const overlay = document.getElementById('search-overlay');
    const backdrop = document.getElementById('search-backdrop');
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const closeBtn = document.getElementById('search-close');
    const toggleBtn = document.getElementById('search-toggle');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');
    const resultsEl = document.getElementById('search-results');
    const popularEl = document.getElementById('search-popular');
    const recentEl = document.getElementById('search-recent');
    const recentListEl = document.getElementById('search-recent-list');
    const emptyEl = document.getElementById('search-empty');
    const configEl = document.getElementById('search-config');

    const STORAGE_KEY = 'asia_recent_searches';
    const supabaseUrl = configEl?.dataset.supabaseUrl;
    const supabaseKey = configEl?.dataset.supabaseAnonKey;

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    function getRecent(): string[] {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
    }

    function saveRecent(term: string) {
      const arr = getRecent().filter(s => s !== term);
      arr.unshift(term);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(arr.slice(0, 5)));
    }

    function renderRecent() {
      const recent = getRecent();
      if (!recent.length || !recentEl || !recentListEl) { recentEl?.classList.add('hidden'); return; }
      recentListEl.innerHTML = '';
      recent.forEach(term => {
        const btn = document.createElement('button');
        btn.textContent = term;
        btn.className = 'px-3 py-1 rounded-full text-sm bg-muted hover:bg-muted/80 transition-colors';
        btn.addEventListener('click', () => { if (input) { input.value = term; doSearch(term); } });
        recentListEl.appendChild(btn);
      });
      recentEl.classList.remove('hidden');
    }

    function showIdle() {
      renderRecent();
      popularEl?.classList.remove('hidden');
      resultsEl?.classList.add('hidden');
      emptyEl?.classList.add('hidden');
    }

    function openSearch() {
      overlay?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input?.focus(), 50);
      showIdle();
    }

    function closeSearch() {
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
      if (input) input.value = '';
      if (debounceTimer) clearTimeout(debounceTimer);
      showIdle();
    }

    async function doSearch(term: string) {
      const q = term.trim();
      if (!q || !supabaseUrl || !supabaseKey) { showIdle(); return; }
      popularEl?.classList.add('hidden');
      recentEl?.classList.add('hidden');
      emptyEl?.classList.add('hidden');
      resultsEl?.classList.remove('hidden');
      if (resultsEl) resultsEl.innerHTML = '<p class="text-sm text-muted-foreground py-4 text-center">Searching…</p>';

      try {
        const encodedQ = encodeURIComponent(`%${q}%`);
        const url = `${supabaseUrl}/rest/v1/articles?select=title,slug,featured_image_url,categories:primary_category_id(name,slug)&status=eq.published&or=(title.ilike.${encodedQ},excerpt.ilike.${encodedQ})&limit=8&order=published_at.desc`;
        const res = await fetch(url, {
          headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` },
        });
        const data = await res.json();
        if (!resultsEl) return;
        if (!Array.isArray(data) || data.length === 0) {
          resultsEl.classList.add('hidden');
          emptyEl?.classList.remove('hidden');
          return;
        }
        resultsEl.innerHTML = '';
        data.forEach((article: any) => {
          const catSlug = article.categories?.slug || 'news';
          const a = document.createElement('a');
          a.href = `/${catSlug}/${article.slug}`;
          a.className = 'flex items-center gap-3 rounded-lg px-2 py-2 hover:bg-muted transition-colors';
          a.addEventListener('click', () => saveRecent(q));
          const imgHtml = article.featured_image_url
            ? `<img src="${article.featured_image_url}" alt="" class="w-14 h-10 object-cover rounded shrink-0" />`
            : `<div class="w-14 h-10 rounded bg-muted shrink-0"></div>`;
          a.innerHTML = `
            ${imgHtml}
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold leading-snug line-clamp-2">${article.title}</p>
              ${article.categories ? `<span class="text-xs text-muted-foreground">${article.categories.name}</span>` : ''}
            </div>
          `;
          resultsEl.appendChild(a);
        });
      } catch {
        if (resultsEl) resultsEl.innerHTML = '<p class="text-sm text-muted-foreground py-4 text-center">Search unavailable</p>';
      }
    }

    toggleBtn?.addEventListener('click', openSearch);
    mobileSearchBtn?.addEventListener('click', openSearch);
    closeBtn?.addEventListener('click', closeSearch);
    backdrop?.addEventListener('click', closeSearch);

    input?.addEventListener('input', () => {
      const val = input.value;
      if (!val.trim()) { showIdle(); return; }
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => doSearch(val), 350);
    });

    input?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { closeSearch(); return; }
      if (e.key === 'Enter') {
        const val = input.value.trim();
        if (val) { saveRecent(val); doSearch(val); }
      }
    });

    document.querySelectorAll<HTMLButtonElement>('.search-popular-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const term = chip.dataset.term || '';
        if (input && term) { input.value = term; doSearch(term); }
      });
    });
  }

  initNav();
  initSearch();
  document.addEventListener('astro:after-swap', () => { initNav(); initSearch(); });
</script>
