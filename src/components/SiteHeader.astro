---
import { siteConfig } from '../site.config';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');

const navItems = [
  { href: '/news',     label: 'News' },
  { href: '/business', label: 'Business' },
  { href: '/life',     label: 'Life' },
  { href: '/learn',    label: 'Learn' },
  { href: '/create',   label: 'Create' },
  { href: '/policy',   label: 'Policy' },
  { href: '/voices',   label: 'Voices' },
];

const toolsItems = [
  { href: '/tools',             label: 'All Tools',    desc: 'Browse all AI tools for Asia' },
  { href: '/guides',            label: 'Guides',       desc: 'Step-by-step AI guides for every skill level' },
  { href: '/events',            label: 'Events',       desc: 'AI conferences and meetups across Asia' },
  { href: '/tools/ai-glossary', label: 'AI Glossary',  desc: '470+ AI terms explained in plain language' },
  { href: '/ai-companies',      label: 'AI Companies', desc: 'Directory of AI companies across Asia' },
  { href: '/ai-policy-atlas',   label: 'Policy Atlas', desc: 'Track AI regulation across Asia-Pacific' },
  { href: '/prompts',           label: 'Prompts',      desc: 'Ready-to-use prompts for every platform' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container mx-auto px-4">
    <div class="flex h-24 items-center justify-between">

      <!-- Logo -->
      <div class="flex items-center gap-8">
        <a href="/" class="flex shrink-0 items-center group" aria-label={`${siteConfig.name} home`}>
          <img src={siteConfig.logoUrl} alt={siteConfig.name} width="192" height="48" style="height:48px;width:auto;" class="transition-opacity duration-200 group-hover:opacity-80" />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center space-x-1" aria-label="Primary navigation">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'text-sm font-medium tracking-wide uppercase px-3 py-1.5 border-b-2 transition-all duration-200 hover:text-primary hover:border-primary',
                isActive(href) ? 'text-primary border-primary' : 'border-transparent text-foreground/80'
              ]}
            >
              {label}
            </a>
          ))}

          <!-- Tools dropdown -->
          <div class="nav-dropdown relative" data-dropdown>
            <button
              class:list={[
                'text-sm font-medium tracking-wide uppercase px-3 py-1.5 border-b-2 transition-all duration-200 hover:text-primary hover:border-primary flex items-center gap-1 cursor-pointer select-none',
                toolsItems.some(t => isActive(t.href)) ? 'text-primary border-primary' : 'border-transparent text-foreground/80'
              ]}
              data-dropdown-trigger
              aria-haspopup="true"
              aria-expanded="false"
            >
              Tools
              <svg class="dropdown-chevron h-3 w-3 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-panel absolute left-0 top-full mt-1.5 hidden w-72 rounded-xl border border-border bg-background shadow-xl p-2 z-[60]">
              {toolsItems.map(({ href, label, desc }) => (
                <a href={href} class="flex items-start gap-3 w-full rounded-lg px-3 py-2.5 hover:bg-muted/80 transition-colors">
                  <div class="flex flex-col">
                    <span class="text-sm font-semibold text-foreground">{label}</span>
                    <span class="text-xs text-muted-foreground leading-snug">{desc}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </nav>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-1">
        <a
          href="/search"
          aria-label="Search"
          class="flex h-10 w-10 items-center justify-center text-muted-foreground hover:text-foreground transition-colors rounded-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>

        <a
          href="/auth"
          aria-label="Sign in / Account"
          class="hidden md:flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </a>

        <a
          href="/newsletter"
          class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90"
          style="background-color:hsl(var(--primary))"
        >
          Newsletter
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="md:hidden flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        >
          <svg id="hamburger-icon" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg id="close-icon" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden border-t border-border/40"
    aria-label="Mobile navigation"
  >
    <div class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-background border-l border-border z-[70] overflow-y-auto pb-[env(safe-area-inset-bottom)] transition-transform duration-300 ease-out translate-x-full" id="mobile-panel">
      <div class="flex flex-col p-5">
        <div class="flex justify-between items-center mb-4">
          <span class="font-semibold text-lg">Menu</span>
          <button id="mobile-close" class="flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground hover:bg-muted transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>

        <a href="/search" class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg bg-muted/50 text-muted-foreground text-sm mb-5 hover:bg-muted transition-colors">
          <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span>Search articles...</span>
        </a>

        <span class="text-xs uppercase tracking-wider text-muted-foreground font-semibold mb-2">Categories</span>
        <div class="flex flex-col space-y-1 mb-4">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-primary',
                isActive(href) ? 'text-primary' : 'text-foreground'
              ]}
            >
              {label}
            </a>
          ))}
          <span class="text-xs uppercase tracking-wider text-muted-foreground font-semibold pt-2 px-3">Tools</span>
          {toolsItems.map(({ href, label }) => (
            <a href={href} class="block rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-primary pl-5 text-muted-foreground">
              {label}
            </a>
          ))}
        </div>

        <div class="border-t border-border my-2" />
        <a href="/auth" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium hover:text-primary transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Sign In
        </a>
        <a href="/newsletter" class="mt-2 flex items-center justify-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90" style="background-color:hsl(var(--primary))">
          Subscribe to Newsletter
        </a>
      </div>
    </div>
    <!-- Backdrop -->
    <div id="mobile-backdrop" class="fixed inset-0 bg-background/60 backdrop-blur-sm z-[60] hidden"></div>
  </nav>
</header>

<script>
  function initNav() {
    // Dropdown toggles
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
      const trigger = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
      const panel = dropdown.querySelector<HTMLElement>('.dropdown-panel');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !panel.classList.contains('hidden');
        document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<SVGElement>('.dropdown-chevron').forEach(c => c.style.transform = '');
        document.querySelectorAll<HTMLButtonElement>('[data-dropdown-trigger]').forEach(t => t.setAttribute('aria-expanded', 'false'));
        if (!isOpen) {
          panel.classList.remove('hidden');
          const chevron = trigger.querySelector<SVGElement>('.dropdown-chevron');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    document.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<SVGElement>('.dropdown-chevron').forEach(c => c.style.transform = '');
      document.querySelectorAll<HTMLButtonElement>('[data-dropdown-trigger]').forEach(t => t.setAttribute('aria-expanded', 'false'));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('.dropdown-panel').forEach(p => p.classList.add('hidden'));
        closeMobile();
      }
    });

    // Mobile menu
    const mobileToggle = document.getElementById('mobile-menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const mobilePanel = document.getElementById('mobile-panel');
    const mobileBackdrop = document.getElementById('mobile-backdrop');
    const mobileClose = document.getElementById('mobile-close');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIconEl = document.getElementById('close-icon');

    function openMobile() {
      mobileNav?.classList.remove('hidden');
      mobileBackdrop?.classList.remove('hidden');
      requestAnimationFrame(() => mobilePanel?.classList.replace('translate-x-full', 'translate-x-0'));
      mobileToggle?.setAttribute('aria-expanded', 'true');
      hamburgerIcon?.classList.add('hidden');
      closeIconEl?.classList.remove('hidden');
    }

    function closeMobile() {
      mobilePanel?.classList.replace('translate-x-0', 'translate-x-full');
      mobileBackdrop?.classList.add('hidden');
      setTimeout(() => mobileNav?.classList.add('hidden'), 300);
      mobileToggle?.setAttribute('aria-expanded', 'false');
      hamburgerIcon?.classList.remove('hidden');
      closeIconEl?.classList.add('hidden');
    }

    mobileToggle?.addEventListener('click', () => {
      if (mobileNav?.classList.contains('hidden')) openMobile(); else closeMobile();
    });
    mobileClose?.addEventListener('click', closeMobile);
    mobileBackdrop?.addEventListener('click', closeMobile);
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
