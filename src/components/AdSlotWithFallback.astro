---
/**
 * AdSense slot with 3 Before 9 house-ad fallback.
 * After 2.5s, if the slot is unfilled (data-ad-status="unfilled" or no
 * content / zero height), hides the ins and shows the house ad image.
 * Tracks house_ad_click -> dataLayer for GTM/GA4.
 */
interface Props {
  client: string;
  slot: string;
  format?: string;
  position?: string;
  minHeight?: string;
}

const {
  client,
  slot,
  format = 'rectangle',
  position = 'sidebar',
  minHeight = '250px',
} = Astro.props;

// Unique ID per render so multiple slots on one page don't collide
const uid = `ad-${slot.replace(/[^a-z0-9]/gi, 'x')}-${Math.random().toString(36).slice(2, 8)}`;
---

<div style={`position:relative;min-height:${minHeight}`}>
  <ins
    id={uid}
    class="adsbygoogle block"
    style={`display:block;min-height:${minHeight};width:100%`}
    data-ad-client={client}
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive="false"
  />
  <a
    id={`${uid}-house`}
    href="https://open.spotify.com/show/0K7PwEgfBQn38UrhcOGojf?si=kR9TFMOzQiOTCbvDKlMKGw"
    target="_blank"
    rel="noopener"
    aria-label="3 Before 9 - Daily Asia-Pacific AI News on Spotify"
    style="display:none;text-decoration:none"
    class="block w-[300px] mx-auto"
  >
    <img
      src="/ads/3b9-spotify-300x250.png"
      alt="3 Before 9 - Daily Asia-Pacific AI News on Spotify"
      width="300"
      height="250"
      loading="lazy"
    />
  </a>
</div>

<script is:inline define:vars={{ _uid: uid, _adPosition: position }}>
  (function () {
    // Queue the AdSense slot push (works even if adsbygoogle.js not yet loaded)
    try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (_) {}

    // After 2.5 s check whether the slot was filled
    setTimeout(function () {
      var ins = document.getElementById(_uid);
      var house = document.getElementById(_uid + '-house');
      if (!ins || !house) return;

      var status = ins.getAttribute('data-ad-status');
      var filled = status === 'filled' ||
        (!status && ins.offsetHeight > 10 && ins.innerHTML.trim().length > 0);

      if (!filled) {
        ins.style.display = 'none';
        house.style.display = 'block';
        house.addEventListener('click', function () {
          (window.dataLayer = window.dataLayer || []).push({
            event: 'house_ad_click',
            ad_name: '3b9-spotify',
            ad_position: _adPosition,
            page_path: window.location.pathname,
          });
        }, { once: true });
      }
    }, 2500);
  })();
</script>
