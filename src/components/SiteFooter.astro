---
import { siteConfig } from '../site.config';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-card mt-16 pb-16 md:pb-0">
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="block mb-3">
          <img src={siteConfig.logoUrl} alt={siteConfig.name} class="h-10 w-auto object-contain" />
        </a>
        <p class="text-sm text-muted-foreground mb-5 leading-relaxed">{siteConfig.tagline}</p>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/company/ai-in-asia" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-muted-foreground hover:text-foreground transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={siteConfig.spotifyShowUrl} target="_blank" rel="noopener noreferrer" aria-label="3 Before 9 on Spotify" class="text-muted-foreground hover:text-foreground transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          </a>
          <a href="/rss.xml" target="_blank" rel="noopener noreferrer" aria-label="RSS Feed" class="text-muted-foreground hover:text-foreground transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-8.18v4.819c12.951.115 23.357 10.71 23.497 23.625h4.503c-.145-15.761-12.958-28.558-28-28.444z" /></svg>
          </a>
        </div>
      </div>

      <!-- Explore -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-4">Explore</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/news"     class="text-muted-foreground hover:text-primary transition-colors">News</a></li>
          <li><a href="/business" class="text-muted-foreground hover:text-primary transition-colors">Business</a></li>
          <li><a href="/life"     class="text-muted-foreground hover:text-primary transition-colors">Life</a></li>
          <li><a href="/learn"    class="text-muted-foreground hover:text-primary transition-colors">Learn</a></li>
          <li><a href="/create"   class="text-muted-foreground hover:text-primary transition-colors">Create</a></li>
          <li><a href="/voices"   class="text-muted-foreground hover:text-primary transition-colors">Voices</a></li>
        </ul>
      </div>

      <!-- Tools & Resources -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-4">Tools & Resources</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/guides"            class="text-muted-foreground hover:text-primary transition-colors">AI Guides</a></li>
          <li><a href="/events"            class="text-muted-foreground hover:text-primary transition-colors">Events</a></li>
          <li><a href="/newsletter"        class="text-muted-foreground hover:text-primary transition-colors">Newsletter</a></li>
          <li><a href="/tools/ai-glossary" class="text-muted-foreground hover:text-primary transition-colors">AI Glossary</a></li>
          <li><a href="/ai-companies"      class="text-muted-foreground hover:text-primary transition-colors">AI Companies</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-4">Company</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about"               class="text-muted-foreground hover:text-primary transition-colors">About</a></li>
          <li><a href="/contact"             class="text-muted-foreground hover:text-primary transition-colors">Contact</a></li>
          <li><a href="/advertise"           class="text-muted-foreground hover:text-primary transition-colors">Advertise</a></li>
          <li><a href="/editorial-standards" class="text-muted-foreground hover:text-primary transition-colors">Editorial Standards</a></li>
          <li><a href="/privacy"             class="text-muted-foreground hover:text-primary transition-colors">Privacy Policy</a></li>
          <li><a href="/terms"               class="text-muted-foreground hover:text-primary transition-colors">Terms of Service</a></li>
          <li><a href="/cookie-policy"       class="text-muted-foreground hover:text-primary transition-colors">Cookie Policy</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="container mx-auto px-6 py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-muted-foreground">
      <p>© {year} {siteConfig.name}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="https://you.withthepowerof.ai" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors inline-flex items-center gap-1">
          Part of the You.WithThePowerOf.AI collective
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </a>
        <a href="/rss.xml"     class="hover:text-foreground transition-colors">RSS</a>
        <a href="/sitemap.xml" class="hover:text-foreground transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
