---
import { createServerClient } from '../lib/supabase';
import { siteConfig } from '../site.config';

interface Props {
  totalArticles: number;
  thisWeekCount: number;
}

const { totalArticles, thisWeekCount } = Astro.props;

const supabase = createServerClient(siteConfig.supabaseUrl, siteConfig.supabaseAnonKey);

const [guidesRes, companiesRes] = await Promise.all([
  supabase.from('ai_guides').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  supabase.from('ai_companies').select('id', { count: 'exact', head: true }),
]);

const totalGuides = guidesRes.count ?? 0;
const totalCompanies = companiesRes.count ?? 0;
const countriesCovered = 22;

const hasExpandedStats = totalGuides > 0 || totalCompanies > 0;
---

{totalArticles > 0 && (
  <div class="stats-bar border-t border-border/30">

    <!-- Always-visible summary row -->
    <div class="container mx-auto px-4 py-3 flex items-center justify-between gap-4">
      <div class="flex items-center gap-5 md:gap-8 flex-1 min-w-0">

        <!-- Total articles -->
        <div class="flex items-center gap-2 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 shrink-0"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
          <span class="font-display text-base font-bold text-foreground tabular-nums">{totalArticles.toLocaleString()}</span>
          <span class="text-xs text-muted-foreground hidden sm:inline">Total Articles</span>
        </div>

        <!-- This week -->
        <div class="flex items-center gap-2 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 shrink-0"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          <span class="font-display text-base font-bold text-foreground tabular-nums">+{thisWeekCount}</span>
          <span class="text-xs text-muted-foreground hidden sm:inline">This Week</span>
        </div>

        <!-- Separator + teaser on desktop -->
        {hasExpandedStats && (
          <span class="hidden md:flex items-center gap-1.5 text-xs text-muted-foreground/60">
            <span class="w-px h-3 bg-border/50 inline-block"></span>
            <span>{totalGuides > 0 ? `${totalGuides} guides` : ''}{totalGuides > 0 && totalCompanies > 0 ? ' · ' : ''}{totalCompanies > 0 ? `${totalCompanies} companies` : ''} · {countriesCovered} countries</span>
          </span>
        )}
      </div>

      <!-- Expand toggle -->
      {hasExpandedStats && (
        <button
          id="stats-bar-toggle"
          aria-expanded="false"
          aria-controls="stats-bar-expanded"
          class="flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors shrink-0 px-2 py-1 rounded-md hover:bg-muted/40"
        >
          <span class="hidden sm:inline stats-toggle-label">More stats</span>
          <svg id="stats-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
        </button>
      )}
    </div>

    <!-- Expandable detail grid -->
    {hasExpandedStats && (
      <div
        id="stats-bar-expanded"
        class="overflow-hidden"
        style="max-height: 0; transition: max-height 0.3s ease, opacity 0.3s ease; opacity: 0;"
      >
        <div class="container mx-auto px-4 pb-5 pt-1">
          <div class="border-t border-border/20 pt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-5 md:gap-6">

            <!-- Articles -->
            <a href="/articles" class="group text-center hover:opacity-80 transition-opacity">
              <div class="flex items-center justify-center gap-2 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                <span class="text-xl md:text-2xl font-bold text-amber-500 tabular-nums group-hover:underline">{totalArticles.toLocaleString()}+</span>
              </div>
              <p class="text-xs text-muted-foreground">Articles Published</p>
            </a>

            <!-- Guides -->
            {totalGuides > 0 && (
              <a href="/guides" class="group text-center hover:opacity-80 transition-opacity">
                <div class="flex items-center justify-center gap-2 mb-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  <span class="text-xl md:text-2xl font-bold text-amber-500 tabular-nums group-hover:underline">{totalGuides}+</span>
                </div>
                <p class="text-xs text-muted-foreground">AI Guides</p>
              </a>
            )}

            <!-- Countries -->
            <a href="/about" class="group text-center hover:opacity-80 transition-opacity">
              <div class="flex items-center justify-center gap-2 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                <span class="text-xl md:text-2xl font-bold text-amber-500 tabular-nums group-hover:underline">{countriesCovered}+</span>
              </div>
              <p class="text-xs text-muted-foreground">Countries Covered</p>
            </a>

            <!-- Tools -->
            <a href="/tools" class="group text-center hover:opacity-80 transition-opacity">
              <div class="flex items-center justify-center gap-2 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <span class="text-xl md:text-2xl font-bold text-amber-500 tabular-nums group-hover:underline">15+</span>
              </div>
              <p class="text-xs text-muted-foreground">Interactive Tools</p>
            </a>

            <!-- Companies -->
            {totalCompanies > 0 && (
              <a href="/directory" class="group text-center hover:opacity-80 transition-opacity">
                <div class="flex items-center justify-center gap-2 mb-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
                  <span class="text-xl md:text-2xl font-bold text-amber-500 tabular-nums group-hover:underline">{totalCompanies}+</span>
                </div>
                <p class="text-xs text-muted-foreground">AI Companies Tracked</p>
              </a>
            )}

          </div>
        </div>
      </div>
    )}

  </div>
)}

<script>
  function initStatsBar() {
    const toggle = document.getElementById('stats-bar-toggle');
    const expanded = document.getElementById('stats-bar-expanded');
    const chevron = document.getElementById('stats-chevron');
    const label = toggle?.querySelector('.stats-toggle-label');
    if (!toggle || !expanded) return;

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        expanded.style.maxHeight = '0';
        expanded.style.opacity = '0';
        toggle.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
        if (label) label.textContent = 'More stats';
      } else {
        expanded.style.maxHeight = expanded.scrollHeight + 'px';
        expanded.style.opacity = '1';
        toggle.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        if (label) label.textContent = 'Less';
      }
    });
  }

  initStatsBar();
  document.addEventListener('astro:after-swap', initStatsBar);
</script>
